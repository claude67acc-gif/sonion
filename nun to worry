local function createSlider(parent, labelText, minValue, maxValue, defaultValue, position, isDecimal, callback)
	local sliderHeight = 38
	local currentValue = defaultValue

	local sliderFrame = createInstance("Frame", {
		Size = UDim2.new(1, -24, 0, sliderHeight),
		Position = position,
		BackgroundTransparency = 1,
		Parent = parent
	})

	createInstance("TextLabel", {
		Size = UDim2.new(0.6, 0, 0, 16),
		Position = UDim2.new(0, 0, 0, 0),
		BackgroundTransparency = 1,
		Text = labelText,
		Font = Enum.Font.GothamBold,
		TextSize = 9,
		TextColor3 = Theme.TextMuted,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Center,
		Parent = sliderFrame
	})

	local sliderBg = createInstance("Frame", {
		Size = UDim2.new(1, 0, 0, 6),
		Position = UDim2.new(0, 0, 0, 24),
		BackgroundColor3 = Color3.fromRGB(48, 48, 56),
		BorderSizePixel = 0,
		Parent = sliderFrame
	})
	createCorner(sliderBg, 3)

	local sliderFill = createInstance("Frame", {
		Size = UDim2.new((defaultValue - minValue) / (maxValue - minValue), 0, 1, 0),
		BackgroundColor3 = Theme.Text,
		BorderSizePixel = 0,
		Parent = sliderBg
	})
	createCorner(sliderFill, 3)

	local sliderValLabel = createInstance("TextBox", {
		Size = UDim2.new(0, 35, 0, 18),
		Position = UDim2.new(1, -35, 0, -2),
		BackgroundColor3 = Theme.Input,
		BorderSizePixel = 0,
		Font = Enum.Font.GothamBold,
		Text = string.format(isDecimal and "%.2f" or "%d", defaultValue),
		TextColor3 = Theme.Text,
		TextSize = 10,
		ClearTextOnFocus = false,
		Visible = (labelText ~= "SNAKE DISTANCE"),
		Parent = sliderFrame
	})
	createCorner(sliderValLabel, 4)
	createStroke(sliderValLabel, Theme.Border, 1)

	local sliderActive = false

	local function updateSlider(input)
		local posX = input.Position.X - sliderBg.AbsolutePosition.X
		local percentage = math.clamp(posX / sliderBg.AbsoluteSize.X, 0, 1)
		local rawValue = minValue + (maxValue - minValue) * percentage
		if isDecimal then
			currentValue = math.round(rawValue * 100) / 100
		else
			currentValue = math.round(rawValue)
		end
		
		sliderFill.Size = UDim2.new(percentage, 0, 1, 0)
		sliderValLabel.Text = string.format(isDecimal and "%.2f" or "%d", currentValue)
		callback(currentValue)
	end

	sliderBg.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			sliderActive = true
			updateSlider(input)
		end
	end)

	v_u_3.InputChanged:Connect(function(input)
		if sliderActive and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			updateSlider(input)
		end
	end)

	v_u_3.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			sliderActive = false
		end
	end)

	sliderValLabel.FocusLost:Connect(function(enterPressed)
		local val = tonumber(sliderValLabel.Text)
		if val then
			currentValue = math.clamp(val, minValue, maxValue)
			if not isDecimal then
				currentValue = math.round(currentValue)
			end
			local percentage = (currentValue - minValue) / (maxValue - minValue)
			sliderFill.Size = UDim2.new(percentage, 0, 1, 0)
			sliderValLabel.Text = string.format(isDecimal and "%.2f" or "%d", currentValue)
			callback(currentValue)
		else
			sliderValLabel.Text = string.format(isDecimal and "%.2f" or "%d", currentValue)
		end
	end)

	return {
		Set = function(val)
			currentValue = math.clamp(val, minValue, maxValue)
			local percentage = (currentValue - minValue) / (maxValue - minValue)
			sliderFill.Size = UDim2.new(percentage, 0, 1, 0)
			sliderValLabel.Text = string.format(isDecimal and "%.2f" or "%d", currentValue)
		end
	}
end

