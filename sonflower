local function sharedMakeDraggable(clickFrame, objectToMove)
    -- Stagger window spawn position to prevent stacking
    _G.CmdGuiSpawnOffset = (_G.CmdGuiSpawnOffset or 0) + 35
    if _G.CmdGuiSpawnOffset > 175 then
        _G.CmdGuiSpawnOffset = 35
    end
    local offset = _G.CmdGuiSpawnOffset
    objectToMove.Position = objectToMove.Position + UDim2.new(0, offset - 105, 0, offset - 105)

    local dragging = false
    local dragInput, dragStart, startPos

    local function update(input)
        local delta = input.Position - dragStart
        objectToMove.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end

    local connBegan = clickFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            local overButton = false
            for _, child in ipairs(clickFrame:GetChildren()) do
                if (child:IsA("TextButton") or child:IsA("ImageButton")) and child.Visible then
                    local minX = child.AbsolutePosition.X
                    local maxX = minX + child.AbsoluteSize.X
                    local minY = child.AbsolutePosition.Y
                    local maxY = minY + child.AbsoluteSize.Y
                    if input.Position.X >= minX and input.Position.X <= maxX and input.Position.Y >= minY and input.Position.Y <= maxY then
                        overButton = true
                        break
                    end
                end
            end
            if overButton then return end
            dragging = true
            dragStart = input.Position
            startPos = objectToMove.Position
        end
    end)

    local connChangedLocal = clickFrame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    local connChangedGlobal = UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            update(input)
        end
    end)

    local connEndedGlobal = UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    local screenGui = objectToMove:FindFirstAncestorOfClass("ScreenGui")
    if screenGui then
        screenGui.Destroying:Connect(function()
            connBegan:Disconnect()
            connChangedLocal:Disconnect()
            connChangedGlobal:Disconnect()
            connEndedGlobal:Disconnect()
        end)
    end
end

local function sharedMakeResizable(objectToMove, minWidth, minHeight, theme, onResize)
    minWidth = math.max(minWidth or 200, 200)
    minHeight = math.max(minHeight or 140, 140)
    local textMutedColor = (theme and theme.TextMuted) or Color3.fromRGB(160, 160, 160)
    local textColor = (theme and theme.Text) or Color3.fromRGB(255, 255, 255)
    
    local resizeHandle = createInstance("TextButton", {
        Name = "ResizeHandle",
        Size = UDim2.new(0, 24, 0, 24),
        Position = UDim2.new(1, -24, 1, -24),
        BackgroundTransparency = 1,
        Text = "",
        ClipsDescendants = true,
        ZIndex = 10,
        Parent = objectToMove
    })

    local cornerLineFrame = createInstance("Frame", {
        Name = "CornerLine",
        Size = UDim2.new(0, 16, 0, 16),
        Position = UDim2.new(0, 12, 0, 12),
        BackgroundTransparency = 1,
        Parent = resizeHandle
    })
    createCorner(cornerLineFrame, 8)
    local stroke = createStroke(cornerLineFrame, textMutedColor, 1.5, 0.4)

    local connEnter = resizeHandle.MouseEnter:Connect(function()
        TweenService:Create(stroke, TweenInfo.new(0.15), {Color = textColor, Transparency = 0}):Play()
    end)

    local connLeave = resizeHandle.MouseLeave:Connect(function()
        TweenService:Create(stroke, TweenInfo.new(0.15), {Color = textMutedColor, Transparency = 0.4}):Play()
    end)

    local resizing = false
    local dragStart, startSize
    local lastNormalHeight = objectToMove.Size.Y.Offset

    local connBegan = resizeHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            resizing = true
            dragStart = input.Position
            startSize = objectToMove.AbsoluteSize
        end
    end)

    local connChangedGlobal = UserInputService.InputChanged:Connect(function(input)
        if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            local newWidth = math.max(minWidth or 250, startSize.X + delta.X)
            
            local isCurrentlyMinimized = (objectToMove.Size.Y.Offset <= 45)
            local newHeight
            
            if isCurrentlyMinimized then
                newHeight = startSize.Y
            else
                newHeight = math.max(minHeight or 150, startSize.Y + delta.Y)
                lastNormalHeight = newHeight
            end
            
            local newSize = UDim2.new(0, newWidth, 0, newHeight)
            objectToMove.Size = newSize
            
            if onResize then
                local callbackSize = UDim2.new(0, newWidth, 0, lastNormalHeight)
                onResize(callbackSize)
            end
        end
    end)

    local connEndedGlobal = UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            resizing = false
        end
    end)

    local screenGui = objectToMove:FindFirstAncestorOfClass("ScreenGui")
    if screenGui then
        screenGui.Destroying:Connect(function()
            connEnter:Disconnect()
            connLeave:Disconnect()
            connBegan:Disconnect()
            connChangedGlobal:Disconnect()
            connEndedGlobal:Disconnect()
        end)
    end
end

