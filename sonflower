local function setupSlider(sliderFrame, minVal, maxVal, defaultVal, callback)
    local track = createInstance("Frame", {
        Size = UDim2.new(1, 0, 0, 6),
        Position = UDim2.new(0, 0, 0, 28),
        BackgroundColor3 = Theme.Input,
        BorderSizePixel = 0,
        Parent = sliderFrame
    })
    createCorner(track, 3)
    
    local fill = createInstance("Frame", {
        Size = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = Theme.Accent1,
        BorderSizePixel = 0,
        Parent = track
    })
    createCorner(fill, 3)
    
    local knob = createInstance("Frame", {
        Size = UDim2.new(0, 12, 0, 12),
        Position = UDim2.new(0, -6, 0.5, -6),
        BackgroundColor3 = Theme.Text,
        BorderSizePixel = 0,
        ZIndex = 5,
        Parent = track
    })
    createCorner(knob, 6)
    createStroke(knob, Theme.Border, 1)
    
    local valueText = createInstance("TextLabel", {
        Size = UDim2.new(0.3, 0, 0, 20),
        Position = UDim2.new(0.7, 0, 0, 0),
        BackgroundTransparency = 1,
        Text = string.format("%.1fs", defaultVal),
        Font = Enum.Font.GothamBold,
        TextSize = 11,
        TextColor3 = Theme.Text,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = sliderFrame
    })
    
    local draggingSlider = false
    
    local function updateValue(input)
        local totalWidth = track.AbsoluteSize.X
        local relativeX = input.Position.X - track.AbsolutePosition.X
        local percentage = math.clamp(relativeX / totalWidth, 0, 1)
        
        local val = minVal + percentage * (maxVal - minVal)
        val = math.round(val * 10) / 10
        
        fill.Size = UDim2.new(percentage, 0, 1, 0)
        knob.Position = UDim2.new(percentage, -6, 0.5, -6)
        valueText.Text = string.format("%.1fs", val)
        
        callback(val)
    end
    
    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingSlider = true
            updateValue(input)
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateValue(input)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingSlider = false
        end
    end)
    
