    Velocity = Vector3.new(0, 0, 0),
    AnimTrack = nil,
    OriginalGravity = 196.2,
    SetSpeedSlider = nil
}

local FlyListening = false
local bobbingFrequency = 1.5
local bobbingAmplitude = 0.4
local moveState = {forward = 0, backward = 0, left = 0, right = 0}
local Workspace = game:GetService("Workspace")

local function disableDefaultAnimate()
    local char = LocalPlayer.Character
    local animate = char and char:FindFirstChild("Animate")
    if animate then animate.Disabled = true end
end

local function enableDefaultAnimate()
    local char = LocalPlayer.Character
    local animate = char and char:FindFirstChild("Animate")
    if animate then animate.Disabled = false end
end

local function playFlyAnimation(animId, speed)
    local char = LocalPlayer.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    if Fly.AnimTrack and Fly.AnimTrack.Animation.AnimationId == "rbxassetid://" .. tostring(animId) then
        return
    end
    if Fly.AnimTrack then
        Fly.AnimTrack:Stop(0.1)
        Fly.AnimTrack = nil
    end
    
    disableDefaultAnimate()
    
    local animator = humanoid:FindFirstChildOfClass("Animator") or Instance.new("Animator", humanoid)
    for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
        track:Stop()
    end
    
    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://" .. tostring(animId)
    
    local success, track = pcall(function()
        return animator:LoadAnimation(anim)
    end)
    
    if success and track then
        Fly.AnimTrack = track
        Fly.AnimTrack:Play()
        Fly.AnimTrack:AdjustSpeed(speed or 1)
    end
end

local function stopFlyAnimation()
    if Fly.AnimTrack then
        Fly.AnimTrack:Stop(0.1)
        Fly.AnimTrack = nil
    end
    enableDefaultAnimate()
    local char = LocalPlayer.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    local animator = humanoid and humanoid:FindFirstChildOfClass("Animator")
    if animator then
        for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
            track:Stop()
        end
    end
end

