local function toggleInvis()
    invisActive = not invisActive
    
    for _, p in ipairs(invisParts) do 
        p.Transparency = invisActive and 0.5 or 0 
    end
    
    if invisActive then
        statusText.Text = "INVISIBLE"
        statusText.TextColor3 = Theme.Text
        statusIndicator.BackgroundColor3 = Theme.Text
        statusDot.BackgroundColor3 = Theme.Text
        
        if not invisConn then
            invisConn = RunService.Heartbeat:Connect(function()
                if not invisActive then
                    if invisConn then invisConn:Disconnect(); invisConn = nil end
                    return
                end
                if UserInputService.MouseBehavior == Enum.MouseBehavior.LockCenter then return end
                if not HRP or not humanoid then return end
                
                local cf = HRP.CFrame
                local co = humanoid.CameraOffset
                local below = cf * CFrame.new(0, -200, 0)
                
                HRP.CFrame = below
                humanoid.CameraOffset = below:ToObjectSpace(CFrame.new(cf.Position)).Position
                RunService.RenderStepped:Wait()
                HRP.CFrame = cf
                humanoid.CameraOffset = co
            end)
        end
    else
        statusText.Text = "VISIBLE"
        statusText.TextColor3 = Theme.TextMuted
        statusIndicator.BackgroundColor3 = Theme.TextMuted
        statusDot.BackgroundColor3 = Theme.TextMuted
        
