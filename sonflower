-- Function to clean up leftover body movers from previous executions
local function cleanUpLeftovers()
    if humanoidRootPart then
        for _, child in ipairs(humanoidRootPart:GetChildren()) do
            if child.Name == "HeightLock" or child:IsA("BodyGyro") then
                child:Destroy()
            end
        end
