local function createToggle(parent, labelText, defaultValue, layoutOrder, callback)
    local toggleFrame = createInstance("Frame", {
        Size = UDim2.new(1, 0, 0, 34), 
        BackgroundTransparency = 1,
        LayoutOrder = layoutOrder,
        Parent = parent
    })

    local label = createInstance("TextLabel", {
        Size = UDim2.new(1, -50, 1, 0), 
        BackgroundTransparency = 1,
        Text = labelText,
        Font = Enum.Font.GothamBold,
        TextSize = 10,
        TextColor3 = Theme.TextMuted,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center, 
        Parent = toggleFrame
    })

    local switchTrack = createInstance("Frame", {
        Size = UDim2.new(0, 34, 0, 18), 
        Position = UDim2.new(1, -34, 0.5, -9),
        BackgroundColor3 = defaultValue and Theme.Accent1 or Theme.InactiveToggle,
        BorderSizePixel = 0,
        Parent = toggleFrame
    })
    createCorner(switchTrack, 9)

    local switchKnob = createInstance("Frame", {
        Size = UDim2.new(0, 12, 0, 12),
        Position = defaultValue and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6),
        BackgroundColor3 = defaultValue and Theme.Header or Theme.Text,
        BorderSizePixel = 0,
        Parent = switchTrack
    })
    createCorner(switchKnob, 6)

    local state = defaultValue

    local function setToggle(newState)
        state = newState
        local targetPos = state and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6)
        local targetColor = state and Theme.Accent1 or Theme.InactiveToggle
        local knobColor = state and Theme.Header or Theme.Text

        TweenService:Create(switchKnob, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = targetPos,
            BackgroundColor3 = knobColor
        }):Play()
        TweenService:Create(switchTrack, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundColor3 = targetColor}):Play()

        callback(state)
    end

    local clickBtn = createInstance("TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        Parent = toggleFrame
    })

    clickBtn.MouseButton1Click:Connect(function()
        setToggle(not state)
    end)
end

-- Core Runtime State Modifier Processing Blocks
local function updateMovementProperties()
    if FeatureStates.GravityTripActive then return end -- Don't overwrite zero gravity while tripped
    local char = lp.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.WalkSpeed = FeatureStates.WalkSpeed
        hum.JumpPower = FeatureStates.JumpPower
        hum.UseJumpPower = true
    end
    workspace.Gravity = FeatureStates.Gravity
end

local function applyEgorState()
    if FeatureStates.EgorActive then
        statusText.Text = "ACTIVE"
        statusText.TextColor3 = Theme.Text
        statusIndicator.BackgroundColor3 = Theme.Text
        statusDot.BackgroundColor3 = Theme.Text
        
        RunService:BindToRenderStep("EgorRun", Enum.RenderPriority.Character.Value + 1, function()
            local char = lp.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if hum then
                for _, track in ipairs(hum:GetPlayingAnimationTracks()) do
                    track:AdjustSpeed(FeatureStates.AnimSpeed)
                end
            end
        end)
    else
        RunService:UnbindFromRenderStep("EgorRun")
        statusText.Text = "STANDBY"
        statusText.TextColor3 = Theme.TextMuted
        statusIndicator.BackgroundColor3 = Theme.TextMuted
        statusDot.BackgroundColor3 = Theme.TextMuted
        
        local char = lp.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum then
            for _, track in ipairs(hum:GetPlayingAnimationTracks()) do
                track:AdjustSpeed(1)
            end
        end
    end
end

