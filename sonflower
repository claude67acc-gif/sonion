-- Core Operational Backend Functionality Loop
local function stopSpin()
    if spinConn then spinConn:Disconnect(); spinConn = nil end
    if spinBodyVel then spinBodyVel:Destroy(); spinBodyVel = nil end
    spinActive = false; spinDirection = 0
    updateUIState("IDLE", Theme.TextMuted)
end

local function startSpin(dir)
    stopSpin()
    local char = player.Character; if not char then return end
    local currentHrp = char:FindFirstChild("HumanoidRootPart"); if not currentHrp then return end
    
    spinActive = true; spinDirection = dir
    spinBodyVel = Instance.new("BodyAngularVelocity")
    spinBodyVel.MaxTorque = Vector3.new(0, math.huge, 0)
    spinBodyVel.AngularVelocity = Vector3.new(0, spinSpeed * dir, 0)
    spinBodyVel.Parent = currentHrp
    
    local targetVel = Vector3.new(0, spinSpeed * spinDirection, 0)
    spinConn = RunService.Heartbeat:Connect(function()
        if spinBodyVel then
            local want = Vector3.new(0, spinSpeed * spinDirection, 0)
            if want ~= targetVel then targetVel = want; spinBodyVel.AngularVelocity = targetVel end
        end
        if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then stopSpin() end
    end)
    updateUIState(dir == 1 and "FORWARD ACTIVE" or "REVERSE ACTIVE", Theme.Text)
end

