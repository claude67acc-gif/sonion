local function restore()
    if not isMinimized then return end
    isMinimized = false

    local t1 = TweenService:Create(mainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = normalSize,
    })
    t1:Play()
    t1.Completed:Connect(function()
        if not isMinimized then
            headerCover.Visible = true
            headerSeparator.Visible = true
            content.Visible = true
            
        end
    end)
end

