-- Teleport Feature Logic & States
local TeleportActive = false
local MobileTeleportActive = false
local TeleportKeybind = Enum.KeyCode.F
local TeleportListening = false
local TeleportTool = nil

local function executeTeleportPhysics()
    local char = LocalPlayer.Character
    if not char then return end
    
    local hm = char:FindFirstChildOfClass("Humanoid")
    if hm and hm.SeatPart then 
        hm.Sit = false 
        task.wait(0.05) 
    end
    
    local root = char:FindFirstChild("HumanoidRootPart") or (hm and hm.RootPart)
    if not root then return end
    
    local mouse = LocalPlayer:GetMouse()
    local targetPosition = mouse.Hit.Position

    local hh = hm and hm.HipHeight > 0 and (hm.HipHeight + 1) or 4
    root.CFrame = CFrame.new(targetPosition, Vector3.new(root.Position.X, targetPosition.Y, root.Position.Z)) * CFrame.Angles(0, math.pi, 0) + Vector3.new(0, hh, 0)
end

local function updateMobileTeleportState()
    -- Clean up all existing Teleport Tools in Backpack and Character
    local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
    if backpack then
        for _, child in ipairs(backpack:GetChildren()) do
            if child.Name == "Teleport Tool" and child:IsA("Tool") then
                child:Destroy()
            end
        end
    end
    if LocalPlayer.Character then
        for _, child in ipairs(LocalPlayer.Character:GetChildren()) do
            if child.Name == "Teleport Tool" and child:IsA("Tool") then
                child:Destroy()
            end
        end
    end
    
    if TeleportActive and isMobile then
        TeleportTool = Instance.new("Tool")
        TeleportTool.Name = "Teleport Tool"
        TeleportTool.RequiresHandle = false
        TeleportTool.CanBeDropped = false
        
        TeleportTool.Activated:Connect(executeTeleportPhysics)
        
        local targetBackpack = LocalPlayer:WaitForChild("Backpack", 2)
        if targetBackpack then
            TeleportTool.Parent = targetBackpack
        end
    end
end

