local function createSlider(parent, labelText, minValue, maxValue, defaultValue, layoutOrder, callback)
    local sliderHeight = 30
    local currentValue = defaultValue

    local sliderFrame = createInstance("Frame", {
        Size = UDim2.new(1, 0, 0, sliderHeight),
        BackgroundTransparency = 1,
        LayoutOrder = layoutOrder,
        Parent = parent
    })

    createInstance("TextLabel", {
        Size = UDim2.new(0.4, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = labelText,
        Font = Enum.Font.GothamBold,
        TextSize = 10,
        TextColor3 = Theme.TextMuted,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center,
        Parent = sliderFrame
    })

    -- Background Bar
    local sliderBg = createInstance("Frame", {
        Size = UDim2.new(0, 120, 0, 6),
        Position = UDim2.new(1, -165, 0.5, -3),
        BackgroundColor3 = Color3.fromRGB(48, 48, 56),
        BorderSizePixel = 0,
        Parent = sliderFrame
    })
    createCorner(sliderBg, 3)
    createStroke(sliderBg, Theme.Border, 1)

    -- Fill Bar
    local sliderFill = createInstance("Frame", {
        Size = UDim2.new((defaultValue - minValue) / (maxValue - minValue), 0, 1, 0),
        BackgroundColor3 = Theme.Text,
        BorderSizePixel = 0,
        Parent = sliderBg
    })
    createCorner(sliderFill, 3)

    -- Value TextBox
    local sliderValLabel = createInstance("TextBox", {
        Size = UDim2.new(0, 35, 0, 20),
        Position = UDim2.new(1, -35, 0.5, -10),
        BackgroundColor3 = Theme.Input,
        BorderSizePixel = 0,
        Font = Enum.Font.GothamBold,
        Text = tostring(math.floor(defaultValue)),
        TextColor3 = Theme.Text,
        TextSize = 10,
        ClearTextOnFocus = false,
        Parent = sliderFrame
    })
    createCorner(sliderValLabel, 4)
    createStroke(sliderValLabel, Theme.Border, 1)

    local sliderActive = false

    local function updateSlider(input)
        local posX = input.Position.X - sliderBg.AbsolutePosition.X
        local percentage = math.clamp(posX / sliderBg.AbsoluteSize.X, 0, 1)
        currentValue = math.round(minValue + (maxValue - minValue) * percentage)
        
        sliderFill.Size = UDim2.new(percentage, 0, 1, 0)
        sliderValLabel.Text = tostring(currentValue)
        callback(currentValue)
    end

    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            sliderActive = true
            updateSlider(input)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if sliderActive and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(input)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            sliderActive = false
        end
    end)

    sliderValLabel.FocusLost:Connect(function(enterPressed)
        local val = tonumber(sliderValLabel.Text)
        if val then
            currentValue = math.clamp(val, minValue, maxValue)
            local percentage = (currentValue - minValue) / (maxValue - minValue)
            sliderFill.Size = UDim2.new(percentage, 0, 1, 0)
            sliderValLabel.Text = tostring(currentValue)
            callback(currentValue)
        else
            sliderValLabel.Text = tostring(currentValue)
        end
    end)

    return {
        Set = function(val)
            currentValue = math.clamp(val, minValue, maxValue)
            local percentage = (currentValue - minValue) / (maxValue - minValue)
            sliderFill.Size = UDim2.new(percentage, 0, 1, 0)
            sliderValLabel.Text = tostring(currentValue)
        end
    }
end

