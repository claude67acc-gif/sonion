            corner.Parent = segment
            
            segment.Parent = ropeContainer
        end
        
        local angleRad = (k / knotSegments) * math.pi * 2
        local offset = Vector2.new(math.cos(angleRad) * knotRadius, math.sin(angleRad) * knotRadius)
        local pos = knotCenter + offset
        
        segment.Size = UDim2.new(0, 9, 0, 6)
