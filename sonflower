    task.delay(0.2, function()
        if SuggestionsFrame and SuggestionsFrame.Parent then
            SuggestionsFrame.Visible = false
        end
    end)
end)

end)() -- Ends the IIFE scope for PILL COMMAND BAR

--------------------------------------------------------------------------------
-- MOBILE SCREEN AUTO-SCALING SYSTEM
--------------------------------------------------------------------------------
local TrackedFrames = setmetatable({}, {__mode = "k"})

local function applyMobileScale(instance)
    if not instance or not instance.Parent then return end
    local screenSize = ScreenGui.AbsoluteSize
    local shouldScale = isMobile or (screenSize.Y > 0 and screenSize.Y < 600) or (screenSize.X > 0 and screenSize.X < 1100)
    
    if shouldScale then
        local uiScale = instance:FindFirstChild("MobileScale")
        if not uiScale then
            uiScale = Instance.new("UIScale")
            uiScale.Name = "MobileScale"
            uiScale.Scale = 0.45
            uiScale.Parent = instance
        else
            uiScale.Scale = 0.45
        end
        
        -- Center the custom command panels on mobile so they don't open off-screen
        -- (We skip the main hub panel which is parented directly to ScreenGui and anchored at bottom-center)
        if instance.Name == "MainFrame" and instance.Parent ~= ScreenGui and instance.AnchorPoint ~= Vector2.new(0.5, 0.5) then
            instance.AnchorPoint = Vector2.new(0.5, 0.5)
            instance.Position = UDim2.new(0.5, 0, 0.5, 0)
        end
    else
        local uiScale = instance:FindFirstChild("MobileScale")
        if uiScale then
            uiScale:Destroy()
        end
        
        -- Revert AnchorPoint and position of custom command panels if they were centered by mobile scale
        if instance.Name == "MainFrame" and instance.Parent ~= ScreenGui and instance.AnchorPoint == Vector2.new(0.5, 0.5) then
            instance.AnchorPoint = Vector2.new(0, 0)
            instance.Position = UDim2.new(0.5, -instance.Size.X.Offset / 2, 0.4, -instance.Size.Y.Offset / 2)
        end
    end
end

local function trackFrame(instance)
    if instance:IsA("Frame") and (
        instance.Name == "CommandBarFrame" or 
        instance.Name == "MainFrame" or 
        instance.Name == "SuggestionsFrame" or 
        instance.Name == "AttachHubDropdown"
    ) then
        TrackedFrames[instance] = true
        pcall(applyMobileScale, instance)
    end
end

local function updateAllScales()
    for instance in pairs(TrackedFrames) do
        pcall(applyMobileScale, instance)
    end
end

local function initializeTracking(container)
    if not container then return end
    -- Dynamically track newly added frames
    container.DescendantAdded:Connect(function(desc)
        pcall(trackFrame, desc)
    end)
end

task.spawn(function()
    -- Scan our own ScreenGui (very fast, 0ms, contains all startup frames)
    for _, desc in ipairs(ScreenGui:GetDescendants()) do
        pcall(trackFrame, desc)
    end
    
    initializeTracking(UIContainer)
    if UIContainer ~= PlayerGui then
        initializeTracking(PlayerGui)
    end
    
    -- Dynamically update scaling when screen size changes (only updates tracked frames, no lag)
    ScreenGui:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateAllScales)
end)

