local function startSpam()
    local rawText = messageBox.Text
    if rawText == "" then
        statusText.Text = "NO MESSAGE"
        statusText.TextColor3 = Color3.fromRGB(235, 75, 75)
        statusIndicator.BackgroundColor3 = Color3.fromRGB(235, 75, 75)
        return
    end

    local messages = string.split(rawText, "|")

    FeatureStates.ChatSpamActive = true
    statusText.Text = "ACTIVE"
    statusText.TextColor3 = Theme.Text
    statusIndicator.BackgroundColor3 = Theme.Text
    statusDot.BackgroundColor3 = Theme.Text

    actionBtn.Text = "STOP SPAM"
    actionBtn.BackgroundColor3 = Theme.Danger
    actionBtn.TextColor3 = Theme.Text 
    if actionBtnGradient then
        actionBtnGradient.Enabled = false
    end

    task.spawn(function()
        while FeatureStates.ChatSpamActive do
            local msg = messages[currentMessageIndex]
            currentMessageIndex = currentMessageIndex + 1
            if currentMessageIndex > #messages then
                currentMessageIndex = 1
            end

            if FeatureStates.RandomCapitalize then
                msg = randomCapitalize(msg)
            end
            if FeatureStates.WordBypass then
                msg = filterString(msg)
            end
            if FeatureStates.AntiSpam then
                msg = addRandomEnder(msg)
            end

            sendChat(msg)

            local finalDelay = delaySec
            if FeatureStates.AntiSpam then

                finalDelay = finalDelay + (math.random(-10, 10) / 100)
                finalDelay = math.max(0.2, finalDelay)
            end

            task.wait(finalDelay)
        end
    end)
end

