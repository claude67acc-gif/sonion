-- Flashback Operational Engine Logic
---------------------------------------------------------
local flashbackRecords = {}
local maxFlashbackTime = 60
local isRewinding = false

local function getCharacter()
    while not lp.Character or not lp.Character.Parent do
        lp.CharacterAdded:Wait()
    end
    return lp.Character
end

local function recordCurrentState(character)
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    local currentRecord = {
        timestamp = tick(),
        cf = (character.PrimaryPart or hrp).CFrame,
        velocity = hrp.Velocity,
        state = humanoid:GetState()
    }
    table.insert(flashbackRecords, currentRecord)

    local currentTime = tick()
    while #flashbackRecords > 0 and (currentTime - flashbackRecords[1].timestamp) > maxFlashbackTime do
        table.remove(flashbackRecords, 1)
    end
end

local function applyRecord(character, record)
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local primary = character.PrimaryPart or hrp
    primary.CFrame = record.cf
    hrp.Velocity = record.velocity

    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid and record.state then
        pcall(function()
            humanoid:ChangeState(record.state)
        end)
    end
end

local function updateUIState(rewinding)
    if rewinding then
        statusText.Text = "REWINDING"
        statusText.TextColor3 = Theme.Text
        statusIndicator.BackgroundColor3 = Theme.Text
        statusDot.BackgroundColor3 = Theme.Text
    else
        statusText.Text = "RECORDING"
        statusText.TextColor3 = Theme.TextMuted
        statusIndicator.BackgroundColor3 = Theme.TextMuted
        statusDot.BackgroundColor3 = Theme.TextMuted
    end
end

RunService:BindToRenderStep("FlashbackStep", 80, function(dt)
    local character = lp.Character or getCharacter()
    if not character then return end

    if isRewinding then
        if #flashbackRecords > 0 then
            local record = table.remove(flashbackRecords)
            if record then
                applyRecord(character, record)
            end
        else
            isRewinding = false
            updateUIState(false)
        end
    else
        recordCurrentState(character)
    end
end)

