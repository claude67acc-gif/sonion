    local function PlayClip(targetClip, loop)
        if CurrentStopFunc then CurrentStopFunc() end
        local char = lp.Character
        if not char then return end
        local animator = char:WaitForChild("Humanoid"):WaitForChild("Animator")

        for _, track in pairs(animator:GetPlayingAnimationTracks()) do track:Stop() end
        local clipTracks = {}
        CurrentlyPlayingClip = targetClip.Id

        local startTime = tick()
        local processed = {}

        local playbackConnection
        playbackConnection = RunService.Heartbeat:Connect(function()
            local elapsed = tick() - startTime
            if elapsed > targetClip.Duration and not loop then
                playbackConnection:Disconnect()
                for _, d in pairs(clipTracks) do if d.Track.IsPlaying then d.Track:Stop() end end
                if CurrentlyPlayingClip == targetClip.Id then
                    CurrentlyPlayingClip = nil
                    playBtn.Text = "PLAY"
                    playBtn.BackgroundColor3 = Theme.Header
                end
                return
            end

            if loop and elapsed > targetClip.Duration then
                startTime = tick()
                table.clear(processed)
                for _, d in pairs(clipTracks) do if d.Track.IsPlaying then d.Track:Stop() end end
            end

            for i, event in ipairs(targetClip.Events) do
                if not processed[i] and elapsed >= event.Time then
                    processed[i] = true
                    if event.Type == "Start" then
                        local anim = Instance.new("Animation")
                        anim.AnimationId = event.AnimationId
                        local track = animator:LoadAnimation(anim)
                        track:AdjustSpeed(event.Speed)
                        if event.TimePosition then track.TimePosition = event.TimePosition end
                        track:Play()
                        clipTracks[event.AnimationId] = {Track = track}
                    elseif event.Type == "Stop" and clipTracks[event.AnimationId] then
                        clipTracks[event.AnimationId].Track:Stop()
                    elseif event.Type == "Speed" and clipTracks[event.AnimationId] then
                        clipTracks[event.AnimationId].Track:AdjustSpeed(event.Speed)
                    elseif event.Type == "Weight" and clipTracks[event.AnimationId] then
                        clipTracks[event.AnimationId].Track:AdjustWeight(event.Weight)
                    elseif event.Type == "TimeJump" and clipTracks[event.AnimationId] then
                        clipTracks[event.AnimationId].Track.TimePosition = event.NewPosition
                    elseif event.Type == "Freeze" and clipTracks[event.AnimationId] then
                        clipTracks[event.AnimationId].Track:AdjustSpeed(event.IsFrozen and 0 or 1)
                    end
                end
            end
        end)

        return function()
            if playbackConnection then playbackConnection:Disconnect() end
            CurrentlyPlayingClip = nil
            for _, d in pairs(clipTracks) do if d.Track.IsPlaying then d.Track:Stop() end end
        end
    end

    playBtn.MouseButton1Click:Connect(function()
        if stopFunc then
            stopFunc()
            stopFunc = nil
            playBtn.Text = "PLAY"
            playBtn.BackgroundColor3 = Theme.Header
        else
            stopFunc = PlayClip(clip, LoopingClips[clip.Id] or false)
            CurrentStopFunc = stopFunc
            playBtn.Text = "STOP"
            playBtn.BackgroundColor3 = Theme.TextMuted
        end
    end)

    loopBtn.MouseButton1Click:Connect(function()
        LoopingClips[clip.Id] = not LoopingClips[clip.Id]
