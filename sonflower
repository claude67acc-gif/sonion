local function setVoiceMuted(targetPlr)
    local mutedState = not not (_G.MutedPlayers[targetPlr] or _G.HiddenPlayers[targetPlr])
    
    -- 1. Mute AudioDeviceInput under the Player
    local input = targetPlr:FindFirstChildOfClass("AudioDeviceInput") or targetPlr:FindFirstChild("AudioDeviceInput")
    if input then
        pcall(function()
            input.Muted = mutedState
        end)
    end
    
    -- 2. Handle AudioEmitter under their Character
    local char = targetPlr.Character
    if char then
        for _, emitter in ipairs(char:GetDescendants()) do
            if emitter:IsA("AudioEmitter") then
                pcall(function()
                    emitter.Enabled = not mutedState
                end)
            end
        end
    end
    
    -- 3. Handle Wires connected to their input
    if input then
        pcall(function()
            for _, wire in ipairs(game:GetDescendants()) do
                if wire:IsA("Wire") and (wire.SourceInstance == input or wire.TargetInstance == input) then
                    wire.Enabled = not mutedState
                end
            end
        end)
    end
end

-- Listener to enforce voice mute automatically when components spawn
local function setupVoiceMuteConnections(plr)
    -- Watch Player for AudioDeviceInput
    plr.ChildAdded:Connect(function(child)
        if child:IsA("AudioDeviceInput") then
            pcall(function()
                child.Muted = not not (_G.MutedPlayers[plr] or _G.HiddenPlayers[plr])
            end)
        end
    end)
    
    -- Watch Character for AudioEmitter
    plr.CharacterAdded:Connect(function(char)
        char.DescendantAdded:Connect(function(desc)
            if desc:IsA("AudioEmitter") then
                pcall(function()
                    desc.Enabled = not (_G.MutedPlayers[plr] or _G.HiddenPlayers[plr])
                end)
            end
        end)
        for _, emitter in ipairs(char:GetDescendants()) do
            if emitter:IsA("AudioEmitter") then
                pcall(function()
                    emitter.Enabled = not (_G.MutedPlayers[plr] or _G.HiddenPlayers[plr])
                end)
            end
        end
    end)
end

