    if not Fly.IsFlying then
        Fly.IsFlying = true

        Fly.OriginalGravity = Workspace.Gravity
        Workspace.Gravity = 0
        humanoid.PlatformStand = true
        playFlyAnimation(74775071938710, 1) -- Idle hover animation

        local gyro = Instance.new("BodyGyro")
