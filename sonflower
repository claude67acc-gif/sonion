-- Procedural braided rope drawing with a Bowline knot/loop at the bottom (attachment point B)
local function drawRope(ropeContainer, A, B)
    local distance = (B - A).Magnitude
    local angle = math.deg(math.atan2(B.Y - A.Y, B.X - A.X))
    
    local segmentLength = 6
    local numSegments = math.floor(distance / segmentLength)
    if numSegments < 1 then numSegments = 1 end
    
    local children = ropeContainer:GetChildren()
    
    -- Draw main rope stem from A to B
    for i = 0, numSegments do
        local segment = children[i + 1]
        if not segment then
            segment = Instance.new("Frame")
            segment.BorderSizePixel = 0
            segment.AnchorPoint = Vector2.new(0.5, 0.5)
            segment.ZIndex = ropeContainer.ZIndex
            
            local corner = Instance.new("UICorner")
            corner.CornerRadius = UDim.new(0.5, 0)
            corner.Parent = segment
            
            segment.Parent = ropeContainer
        end
        
        local t = i / numSegments
        local pos = A + (B - A) * t
        
        segment.Size = UDim2.new(0, 10, 0, 6)
        segment.Position = UDim2.new(0, round(pos.X), 0, round(pos.Y))
        segment.BackgroundColor3 = (i % 2 == 0) and Color3.fromRGB(240, 240, 240) or Color3.fromRGB(30, 30, 30)
        segment.Rotation = angle + ((i % 2 == 0) and 25 or -25)
        segment.Visible = true
    end
    
    -- Draw Bowline loop/knot at B
    local totalUsed = numSegments + 1
    
    -- Loop details (elliptical loop that hangs around the attachment point)
    local loopRadius = 10
    local loopSegments = 10
    local loopCenter = B + Vector2.new(0, 4) -- hang slightly down
    for j = 1, loopSegments do
        totalUsed = totalUsed + 1
        local segment = children[totalUsed]
        if not segment then
            segment = Instance.new("Frame")
            segment.BorderSizePixel = 0
            segment.AnchorPoint = Vector2.new(0.5, 0.5)
            segment.ZIndex = ropeContainer.ZIndex + 1
            
            local corner = Instance.new("UICorner")
            corner.CornerRadius = UDim.new(0.5, 0)
            corner.Parent = segment
            
            segment.Parent = ropeContainer
        end
        
        local angleRad = (j / loopSegments) * math.pi * 2
        local offset = Vector2.new(math.cos(angleRad) * loopRadius, math.sin(angleRad) * loopRadius * 1.3)
        local pos = loopCenter + offset
        
        segment.Size = UDim2.new(0, 8, 0, 5)
        segment.Position = UDim2.new(0, round(pos.X), 0, round(pos.Y))
        segment.BackgroundColor3 = (j % 2 == 0) and Color3.fromRGB(240, 240, 240) or Color3.fromRGB(30, 30, 30)
        segment.Rotation = math.deg(angleRad) + 90 + ((j % 2 == 0) and 25 or -25)
        segment.Visible = true
    end
    
    -- Knot chunk details (the knot part that binds the loop)
    local knotRadius = 6
    local knotSegments = 6
    local knotCenter = B - Vector2.new(0, 4) -- slightly above B
    for k = 1, knotSegments do
