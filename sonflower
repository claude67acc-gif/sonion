}

Sneak.GetHeightOffset = function(char, hrp, humanoid)
    if not char or not hrp then return 3.0 end
    local hrpY = hrp.Position.Y
    local lowestY = hrpY
    for _, part in ipairs(char:GetChildren()) do
        if part:IsA("BasePart") then
            local name = part.Name:lower()
            if name:find("foot") or name:find("leg") or name:find("sole") then
                local bottomY = part.Position.Y - (part.Size.Y / 2)
                if bottomY < lowestY then lowestY = bottomY end
            end
        end
    end
    local offset = hrpY - lowestY
    if offset > 0.5 and offset < 6 then return offset end
    if humanoid then
        if humanoid.RigType == Enum.HumanoidRigType.R15 then
            return humanoid.HipHeight + (hrp.Size.Y / 2)
        end
    end
    return 3.0
end

Sneak.GetHeightToBaseplate = function(char, hrp, humanoid)
    local baseplateSurfaceY = -8.5
    local feetOffset = Sneak.GetHeightOffset(char, hrp, humanoid)
    return baseplateSurfaceY + feetOffset
end

Sneak.FindGroundLevel = function(char, hrp, humanoid)
    local baseplateSurfaceY = -8.5
    if hrp.Position.Y > baseplateSurfaceY + 5 then
        return hrp.Position.Y
    else
        local raycastParams = RaycastParams.new()
        raycastParams.FilterType = Enum.RaycastFilterType.Exclude
        local filterList = {char, Sneak.SecondBaseplate}
        raycastParams.FilterDescendantsInstances = filterList
        local origin = Vector3.new(hrp.Position.X, 500, hrp.Position.Z)
        local direction = Vector3.new(0, -1000, 0)
        local raycastResult = workspace:Raycast(origin, direction, raycastParams)
        if raycastResult then
            return raycastResult.Position.Y + Sneak.GetHeightOffset(char, hrp, humanoid)
        end
    end
    return 3.0
end

Sneak.SetNoclip = function(state, char)
    if state then
        if not Sneak.NoclipConn then
            Sneak.OriginalCollisions = {}
            if char then
                for _, part in pairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then
                        Sneak.OriginalCollisions[part] = part.CanCollide
                        part.CanCollide = false
                    end
                end
            end
            Sneak.NoclipConn = RunService.Stepped:Connect(function()
                if char and char.Parent then
                    for _, part in pairs(char:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = false
                        end
                    end
                end
            end)
        end
    else
        if Sneak.NoclipConn then
            Sneak.NoclipConn:Disconnect()
            Sneak.NoclipConn = nil
        end
        if char then
            for part, wasCollidable in pairs(Sneak.OriginalCollisions) do
                if part and part.Parent then
                    part.CanCollide = wasCollidable
                end
            end
        end
        Sneak.OriginalCollisions = {}
    end
end

Sneak.TweenPlayerTo = function(targetPosition, targetNoclipState)
    local char = LocalPlayer.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not humanoid or not hrp or Sneak.IsTweening then return end

    Sneak.IsTweening = true

    if not Sneak.NoclipConn then
        Sneak.NoclipConn = RunService.Stepped:Connect(function()
            if char and char.Parent then
                for _, part in pairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end
        end)
    end

    if Sneak.HeightLock then pcall(function() Sneak.HeightLock:Destroy() end) end
    
    Sneak.HeightLock = Instance.new("BodyPosition")
    Sneak.HeightLock.Name = "HeightLock"
    Sneak.HeightLock.MaxForce = Vector3.new(100000, 100000, 100000)
    Sneak.HeightLock.Position = hrp.Position
    Sneak.HeightLock.P = 10000
    Sneak.HeightLock.D = 1000
    Sneak.HeightLock.Parent = hrp

    local originalCFrame = hrp.CFrame
    local originalLookVector = originalCFrame.LookVector
    humanoid.PlatformStand = true

    local targetCFrame = CFrame.new(targetPosition) * CFrame.lookAt(targetPosition, targetPosition + originalLookVector)
    local bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(100000, 100000, 100000)
    bodyGyro.CFrame = targetCFrame
    bodyGyro.P = 10000
    bodyGyro.D = 1000
    bodyGyro.Parent = hrp

    game:GetService("Debris"):AddItem(bodyGyro, Sneak.TweenDuration + 0.1)

    local tweenInfo = TweenInfo.new(Sneak.TweenDuration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local tween = TweenService:Create(Sneak.HeightLock, tweenInfo, {Position = targetPosition})
    tween:Play()

    tween.Completed:Connect(function()
        Sneak.IsTweening = false
        if humanoid and humanoid.Parent then
            humanoid.PlatformStand = false
        end
        if bodyGyro and bodyGyro.Parent then
            bodyGyro:Destroy()
        end
        
        Sneak.SetNoclip(targetNoclipState, char)
        
        if targetNoclipState then
            if Sneak.HeightLock and Sneak.HeightLock.Parent then
                Sneak.HeightLock.MaxForce = Vector3.new(0, 100000, 0)
                Sneak.HeightLock.Position = Vector3.new(0, targetPosition.Y, 0)
            end
        else
            if Sneak.HeightLock then
                pcall(function() Sneak.HeightLock:Destroy() end)
                Sneak.HeightLock = nil
            end
        end
    end)
end

