            "SpinManagerGui", "GlitchManagerGui", "ShadersGui"
        }
        local targets = {game:GetService("CoreGui"), game:GetService("Players").LocalPlayer:FindFirstChild("PlayerGui")}
        for _, parent in ipairs(targets) do
            if parent then
                for _, name in ipairs(guiNames) do
                    local gui = parent:FindFirstChild(name)
                    if gui and gui:IsA("ScreenGui") then
                        if not visible then
                            if gui.Enabled then
                                gui:SetAttribute("MenuHidden", true)
                                gui.Enabled = false
                            end
                        else
