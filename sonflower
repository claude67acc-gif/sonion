    local dLeft = Vector2.new(-barWidth / 2 + 60 * scaleFactor, -barHeight / 2)
    local dRight = Vector2.new(barWidth / 2 - 60 * scaleFactor, -barHeight / 2)
    
    local rotLeft = rotateVector(dLeft, angle)
    local rotRight = rotateVector(dRight, angle)
    
    local leftAttach = Vector2.new(round(currentPos.X + rotLeft.X), round(currentPos.Y + rotLeft.Y))
    local rightAttach = Vector2.new(round(currentPos.X + rotRight.X), round(currentPos.Y + rotRight.Y))
    
    drawRope(LeftString, leftAnchor, leftAttach)
    drawRope(RightString, rightAnchor, rightAttach)
    
    -- Dynamically position dropdown frames perfectly flat below the command bar (ignores rotation of command bar)
    if SuggestionsFrame and SuggestionsFrame.Parent then
        SuggestionsFrame.Position = UDim2.new(0, currentPos.X - barWidth / 2, 0, currentPos.Y + barHeight / 2 + 6)
        SuggestionsFrame.Size = UDim2.new(0, barWidth, 0, SuggestionsFrame.Size.Y.Offset)
        SuggestionsFrame.Rotation = 0
    end
    
    if AttachHubDropdown and AttachHubDropdown.Parent and AttachHubHeight then
        AttachHubDropdown.Position = UDim2.new(0, currentPos.X - barWidth / 2, 0, currentPos.Y + barHeight / 2 + 6)
        AttachHubDropdown.Size = UDim2.new(0, barWidth, 0, AttachHubHeight.Value)
        AttachHubDropdown.Rotation = 0
    end
end

local lastTime = os.clock()
RunService.RenderStepped:Connect(function()
    local now = os.clock()
    local dt = math.min(now - lastTime, 0.1)
    lastTime = now
    
    local screenSize = getScreenSize()
    local restX = round(screenSize.X / 2)
    local shouldScale = isMobile or (screenSize.Y > 0 and screenSize.Y < 600) or (screenSize.X > 0 and screenSize.X < 1100)
    local restY = round(screenSize.Y * (shouldScale and 0.18 or 0.1))
    
    if isDragging then
        local mousePos = UserInputService:GetMouseLocation()
        local targetPos = mousePos - dragOffset
        
        local screenSize = getScreenSize()
        local shouldScale = isMobile or (screenSize.Y > 0 and screenSize.Y < 600) or (screenSize.X > 0 and screenSize.X < 1100)
        local scaleFactor = shouldScale and 0.45 or 1
        local barWidth = 480 * scaleFactor
        local barHeight = 46 * scaleFactor
        
        local minX = barWidth / 2
        local maxX = screenSize.X - barWidth / 2
        local minY = barHeight / 2
        local maxY = screenSize.Y / 2
        
        targetPos = Vector2.new(
            math.clamp(targetPos.X, minX, maxX),
            math.clamp(targetPos.Y, minY, maxY)
        )
        
        local nextPos = currentPos:Lerp(targetPos, 0.25)
        local newVelocity = (nextPos - currentPos) / dt
        velocity = velocity:Lerp(newVelocity, 0.3)
        currentPos = nextPos
        
        angle = angle + (0 - angle) * 0.15
        angularVelocity = 0
    else
        -- Bouncy swing physics (spring-damper)
        local springStiffness = 180
        local damping = 8
        local angularStiffness = 220
        local angularDamping = 12
        local rollForce = 0.15
        
        local forceX = -springStiffness * (currentPos.X - restX) - damping * velocity.X
        local forceY = -springStiffness * (currentPos.Y - restY) - damping * velocity.Y
        
        velocity = velocity + Vector2.new(forceX, forceY) * dt
        currentPos = currentPos + velocity * dt
        
        local angularForce = -angularStiffness * angle - angularDamping * angularVelocity + rollForce * (currentPos.X - restX)
        angularVelocity = angularVelocity + angularForce * dt
        angle = angle + angularVelocity * dt
        
        -- Snapping variables when velocity and position are extremely close to rest
        if velocity.Magnitude < 0.1 and math.abs(angularVelocity) < 0.1 and (currentPos - Vector2.new(restX, restY)).Magnitude < 0.1 and math.abs(angle) < 0.001 then
            currentPos = Vector2.new(restX, restY)
            velocity = Vector2.new(0, 0)
            angle = 0
            angularVelocity = 0
        end
    end
    
    CommandBarFrame.Position = UDim2.new(0, round(currentPos.X), 0, round(currentPos.Y))
    CommandBarFrame.Rotation = (math.abs(angle) < 0.0001) and 0 or math.deg(angle)
    
    updateStrings()
end)

