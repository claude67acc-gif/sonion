    -- Shader Loader Helpers
    local function restoreOriginals(silent)
        if not getgenv().ORIGINAL_LIGHTING or not next(getgenv().ORIGINAL_LIGHTING) then
            return
        end
        local Workspace = game:GetService("Workspace")
        local Lighting = game:GetService("Lighting")
        local CollectionService = game:GetService("CollectionService")
        
        -- Cancel any running background threads
        if getgenv().AURORA_THREAD then
            pcall(function() task.cancel(getgenv().AURORA_THREAD) end)
            getgenv().AURORA_THREAD = nil
        end
        if getgenv().BLACKOUT_THREAD then
            pcall(function() task.cancel(getgenv().BLACKOUT_THREAD) end)
            getgenv().BLACKOUT_THREAD = nil
        end
        if getgenv().BLACKOUT_CONNECTION then
            pcall(function() getgenv().BLACKOUT_CONNECTION:Disconnect() end)
            getgenv().BLACKOUT_CONNECTION = nil
        end
        
        -- Clean up all event connections registered by shaders
        if getgenv().SHADER_CONNECTIONS then
            for _, conn in ipairs(getgenv().SHADER_CONNECTIONS) do
                pcall(function()
                    conn:Disconnect()
                end)
            end
            getgenv().SHADER_CONNECTIONS = {}
        end
        
        -- Restore BasePart Colors
        if getgenv().ORIGINAL_COLORS then
            for part, color in pairs(getgenv().ORIGINAL_COLORS) do
                pcall(function()
                    if part and part.Parent then
                        part.Color = color
                    end
                end)
            end
        end
        
        -- Restore BasePart Materials
        if getgenv().ORIGINAL_MATERIALS then
            for part, material in pairs(getgenv().ORIGINAL_MATERIALS) do
                pcall(function()
                    if part and part.Parent then
                        part.Material = material
                    end
                end)
            end
        end
        
        -- Restore BasePart Reflectances
        if getgenv().ORIGINAL_REFLECTANCES then
            for part, reflectance in pairs(getgenv().ORIGINAL_REFLECTANCES) do
                pcall(function()
                    if part and part.Parent then
                        part.Reflectance = reflectance
                    end
                end)
            end
        end
        
        -- Restore Lighting properties
        local L = getgenv().ORIGINAL_LIGHTING
        if L and L.Ambient then
            pcall(function()
                Lighting.Ambient = L.Ambient
                Lighting.OutdoorAmbient = L.OutdoorAmbient
                Lighting.Brightness = L.Brightness
                Lighting.ColorShift_Bottom = L.ColorShift_Bottom
                Lighting.ColorShift_Top = L.ColorShift_Top
                Lighting.FogColor = L.FogColor
                Lighting.FogEnd = L.FogEnd
                Lighting.FogStart = L.FogStart
                Lighting.GlobalShadows = L.GlobalShadows
                Lighting.ShadowSoftness = L.ShadowSoftness
                Lighting.EnvironmentDiffuseScale = L.EnvironmentDiffuseScale
                Lighting.EnvironmentSpecularScale = L.EnvironmentSpecularScale
                Lighting.ExposureCompensation = L.ExposureCompensation
                Lighting.ClockTime = L.ClockTime
                Lighting.GeographicLatitude = L.GeographicLatitude
            end)
        end
        
        -- Clear current shader effects (Atmosphere, Bloom, Sky, ColorCorrection, etc.)
        Lighting:ClearAllChildren()
        
        -- Restore all original Lighting children (Sky, Atmosphere, Bloom, Blur, etc.)
        if getgenv().ORIGINAL_LIGHTING_CHILDREN then
            for _, childClone in ipairs(getgenv().ORIGINAL_LIGHTING_CHILDREN) do
                pcall(function()
                    local restored = childClone:Clone()
                    restored.Parent = Lighting
                end)
            end
        end
        
        -- Clean up Terrain children and restore original Terrain children (e.g. Clouds)
        local Terrain = Workspace:FindFirstChildOfClass("Terrain")
        if Terrain then
            for _, child in ipairs(Terrain:GetChildren()) do
                pcall(function()
                    child:Destroy()
                end)
            end
            if getgenv().ORIGINAL_TERRAIN_CHILDREN then
                for _, childClone in ipairs(getgenv().ORIGINAL_TERRAIN_CHILDREN) do
                    pcall(function()
                        local restored = childClone:Clone()
                        restored.Parent = Terrain
                    end)
                end
            end
        end
        
        -- Restore original Water Terrain properties
        local W = getgenv().ORIGINAL_WATER
        if Terrain and W then
            pcall(function()
                Terrain.WaterColor = W.WaterColor
                Terrain.WaterReflectance = W.WaterReflectance
                Terrain.WaterTransparency = W.WaterTransparency
                Terrain.WaterWaveSize = W.WaterWaveSize
                Terrain.WaterWaveSpeed = W.WaterWaveSpeed
            end)
        end
        if not silent then
            _G.ShowNotification("Shaders", "Restored original environment settings", 3)
        end
    end
    
    local function executeShader(shaderName)
        local cleanName = string.lower(shaderName:gsub("%.lua$", ""))
        restoreOriginals(true) -- Reset silently before applying new shader
        task.wait(0.15) -- Wait briefly for the environment reset to apply
        
        if EmbeddedShaders[cleanName] then
            task.spawn(function()
                local success, err = pcall(EmbeddedShaders[cleanName])
                if success then
                    _G.ShowNotification("Shaders", "Successfully loaded " .. shaderName .. " (embedded)", 3)
                else
                    _G.ShowNotification("Shader Error", "Error running " .. shaderName .. ": " .. tostring(err), 5)
                end
            end)
        else
            -- If it's a custom shader file scanned dynamically, load from file
            local path = "shaders/" .. shaderName
            if not path:match("%.lua$") then path = path .. ".lua" end
            if isfile(path) then
                local contentStr = readfile(path)
                local func, err = loadstring(contentStr)
                if func then
                    task.spawn(function()
                        local success, executeErr = pcall(func)
                        if success then
                            _G.ShowNotification("Shaders", "Successfully loaded " .. shaderName, 3)
                        else
                            _G.ShowNotification("Shader Error", "Error running " .. shaderName .. ": " .. tostring(executeErr), 5)
                        end
                    end)
                else
                    _G.ShowNotification("Shader Error", "Failed to compile " .. shaderName .. ": " .. tostring(err), 5)
                end
            else
                _G.ShowNotification("Shader Error", "Shader not found: " .. shaderName, 5)
            end
        end
    end
    
    -- Scan shader files and map to UI items
    local knownImages = {
        ["aesthetic"] = "rbxassetid://75296998527139",
        ["anime"] = "rbxassetid://133642809339383",
        ["aurora"] = "rbxassetid://76169528178293",
        ["blackout"] = "rbxassetid://135621967936086",
        ["space"] = "rbxassetid://108784026540132"
    }
    
    local shadersList = {}
    local foundNames = {}
    
    local scanSuccess, files = pcall(function()
        if listfiles then
            return listfiles("shaders")
        end
    end)
    
    if scanSuccess and files then
        for _, path in ipairs(files) do
            local cleanName = path:match("([^/\\]+)%.lua$") or path:match("([^/\\]+)$")
            if cleanName then
                local lowerName = string.lower(cleanName)
                local displayName = cleanName:sub(1,1):upper() .. cleanName:sub(2)
                local img = knownImages[lowerName] or "rbxassetid://10849912193" -- Scenic sky fallback
                table.insert(shadersList, {
                    Name = displayName,
                    Filename = cleanName .. ".lua",
                    Image = img
                })
                foundNames[lowerName] = true
            end
        end
    end
    
    -- Fallback default shaders
    local defaultShaders = {"aesthetic", "anime", "aurora", "blackout", "space"}
    for _, name in ipairs(defaultShaders) do
        if not foundNames[name] then
            local displayName = name:sub(1,1):upper() .. name:sub(2)
            table.insert(shadersList, {
                Name = displayName,
                Filename = name .. ".lua",
                Image = knownImages[name]
            })
        end
    end
    
    -- Restore Default option
    table.insert(shadersList, {
        Name = "RESET",
        Filename = "__restore__",
        Image = ""
    })
    
    -- Build Card Elements
    for i, shader in ipairs(shadersList) do
        local card = createInstance("Frame", {
            Name = shader.Name,
            BackgroundColor3 = Theme.Panel,
            BorderSizePixel = 0,
            LayoutOrder = i,
            Parent = scrollFrame
        })
        createCorner(card, 10)
        local uiScale = createInstance("UIScale", { Parent = card })
        
        local txtLabel
        if shader.Filename == "__restore__" then
            txtLabel = createInstance("TextLabel", {
                Name = "Title",
                Size = UDim2.new(1, -12, 1, -12),
                Position = UDim2.new(0, 6, 0, 6),
                BackgroundTransparency = 1,
                Text = shader.Name,
                Font = Enum.Font.GothamBold,
                TextSize = 12,
                TextColor3 = Theme.TextMuted,
                TextXAlignment = Enum.TextXAlignment.Center,
                TextYAlignment = Enum.TextYAlignment.Center,
                Parent = card
            })
        else
            local imgLabel = createInstance("ImageLabel", {
                Name = "Thumbnail",
                Size = UDim2.new(0.92, 0, 0.615, 0),
                Position = UDim2.new(0.04, 0, 0.046, 0),
                BackgroundTransparency = 1,
                Image = shader.Image,
                ScaleType = Enum.ScaleType.Crop,
                Parent = card
            })
            createCorner(imgLabel, 8)
            
            txtLabel = createInstance("TextLabel", {
                Name = "Title",
                Size = UDim2.new(0.92, 0, 0.246, 0),
                Position = UDim2.new(0.04, 0, 0.707, 0),
                BackgroundTransparency = 1,
                Text = shader.Name,
                Font = Enum.Font.GothamMedium,
                TextSize = 11,
                TextColor3 = Theme.TextMuted,
                TextXAlignment = Enum.TextXAlignment.Center,
                TextYAlignment = Enum.TextYAlignment.Center,
                Parent = card
            })
        end
        
        local btn = createInstance("TextButton", {
            Name = "Button",
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Text = "",
            ZIndex = 5,
            Parent = card
        })
        
        -- Hover effects
        btn.MouseEnter:Connect(function()
            TweenService:Create(txtLabel, TweenInfo.new(0.15), {TextColor3 = Theme.Text}):Play()
            TweenService:Create(card, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(30, 30, 30)}):Play()
            TweenService:Create(uiScale, TweenInfo.new(0.15), {Scale = 1.04}):Play()
        end)
        
        btn.MouseLeave:Connect(function()
            TweenService:Create(txtLabel, TweenInfo.new(0.15), {TextColor3 = Theme.TextMuted}):Play()
            TweenService:Create(card, TweenInfo.new(0.15), {BackgroundColor3 = Theme.Panel}):Play()
            TweenService:Create(uiScale, TweenInfo.new(0.15), {Scale = 1.0}):Play()
        end)
        
        -- Action
        btn.MouseButton1Click:Connect(function()
            if shader.Filename == "__restore__" then
                restoreOriginals()
            else
                executeShader(shader.Filename)
            end
        end)
    end
    
    updateGridCellSize(normalSize)
end









