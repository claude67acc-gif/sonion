-- Rewind Feature States & Logic
local RewindActive = false
local RewindKeybind = Enum.KeyCode.C
local RewindMobileActive = false
local RewindMobileBtn = nil
local flashbackRecords = {}
local maxFlashbackTime = 60
local isRewinding = false

local function getCharacter()
    while not LocalPlayer.Character or not LocalPlayer.Character.Parent do
        LocalPlayer.CharacterAdded:Wait()
    end
    return LocalPlayer.Character
end

RunService:BindToRenderStep("FlashbackStepMain", 80, function(dt)
    if not RewindActive then return end
    local character = LocalPlayer.Character or getCharacter()
    if not character then return end

    if isRewinding then
        if #flashbackRecords > 0 then
            local record = table.remove(flashbackRecords)
            if record then
                local hrp = character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local primary = character.PrimaryPart or hrp
                    primary.CFrame = record.cf
                    hrp.Velocity = record.velocity
                    
                    local humanoid = character:FindFirstChildOfClass("Humanoid")
                    if humanoid and record.state then
                        pcall(function()
                            humanoid:ChangeState(record.state)
                        end)
                    end
                end
            end
        else
            isRewinding = false
        end
    else
        local hrp = character:FindFirstChild("HumanoidRootPart")
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if hrp and humanoid then
            local currentRecord = {
                timestamp = tick(),
                cf = (character.PrimaryPart or hrp).CFrame,
                velocity = hrp.Velocity,
                state = humanoid:GetState()
            }
            table.insert(flashbackRecords, currentRecord)

            local currentTime = tick()
            while #flashbackRecords > 0 and (currentTime - flashbackRecords[1].timestamp) > maxFlashbackTime do
                table.remove(flashbackRecords, 1)
            end
        end
    end
end)

