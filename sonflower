-- Check if mouse click is over any interactive GUI element (supports grandchildren)
local function isOverInteractiveGui(inputPos)
    local elements = {SearchBox, PersonButton, CircleButton}
    for _, desc in ipairs(elements) do
        if desc and desc.Visible then
            local success, absPos = pcall(function() return desc.AbsolutePosition end)
            local success2, absSize = pcall(function() return desc.AbsoluteSize end)
            if success and success2 and absPos and absSize then
                local minX = absPos.X
                local maxX = minX + absSize.X
                local minY = absPos.Y
                local maxY = minY + absSize.Y
                if inputPos.X >= minX and inputPos.X <= maxX and inputPos.Y >= minY and inputPos.Y <= maxY then
                    return true
                end
            end
        end
    end
    return false
end

