        bv.Parent = hrp
        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        bv.Velocity = Vector3.new(0, 0.1, 0)

        Fly.Velocity = Vector3.new(0, 0, 0)

        local flightUpdate = RunService.RenderStepped:Connect(function(deltaTime)
            local cam = Workspace.CurrentCamera
            local fwd = moveState.forward - moveState.backward
            local side = moveState.right - moveState.left

            local inputVec = (cam.CFrame.LookVector * fwd) + (cam.CFrame.RightVector * side)
            if fwd ~= 0 then
                inputVec = inputVec + Vector3.new(0, 0.2 * fwd, 0)
            end

            local bobbing = math.sin(tick() * bobbingFrequency) * bobbingAmplitude
            local desiredVelocity = Vector3.new(0, 0, 0)

            if inputVec.Magnitude > 0 then
                desiredVelocity = inputVec.Unit * Fly.Speed
            else
                desiredVelocity = Vector3.new(0, bobbing, 0)
            end

            Fly.Velocity = Fly.Velocity:Lerp(desiredVelocity, 0.1)
            bv.Velocity = Fly.Velocity

            local desiredCF
            if fwd == 0 and side == 0 then
                playFlyAnimation(74775071938710, 1) -- Idle hover animation
                desiredCF = CFrame.lookAt(Vector3.new(0, 0, 0), cam.CFrame.LookVector * Vector3.new(1, 0, 1))
            else
                -- Cycle superhero animations based on speed slider value
                if Fly.Speed <= 50 then
                    playFlyAnimation(115250948577308, 1) -- Normal fly
                elseif Fly.Speed <= 120 then
                    playFlyAnimation(135663683709646, 1) -- Boost fly
                elseif Fly.Speed <= 220 then
                    playFlyAnimation(101291673584393, 1) -- Hyper fly
                else
                    playFlyAnimation(92365791487740, 1) -- Supersonic fly
                end

                local flatLook = (cam.CFrame.LookVector * Vector3.new(1, 0, 1)).Unit
                desiredCF = CFrame.lookAt(Vector3.new(0, 0, 0), flatLook)
            end
            
            if Fly.CurrentCF then
                Fly.CurrentCF = Fly.CurrentCF:Lerp(desiredCF, Fly.LerpCoef)
            else
                Fly.CurrentCF = desiredCF
            end
            gyro.CFrame = Fly.CurrentCF
        end)
        table.insert(Fly.Conns, flightUpdate)

        local function onFlyInputBegan(input, gameProc)
            if gameProc then return end
            if input.UserInputType == Enum.UserInputType.Keyboard then
                local key = input.KeyCode
                if key == Enum.KeyCode.W then moveState.forward = 1
                elseif key == Enum.KeyCode.S then moveState.backward = 1
                elseif key == Enum.KeyCode.A then moveState.left = 1
                elseif key == Enum.KeyCode.D then moveState.right = 1
                elseif key == Enum.KeyCode.LeftControl then
                    local newSpeed = 50
                    if Fly.Speed < 120 then
                        newSpeed = 120
                    elseif Fly.Speed < 220 then
                        newSpeed = 220
                    elseif Fly.Speed < 350 then
                        newSpeed = 350
                    else
                        newSpeed = 50
                    end
                    Fly.Speed = newSpeed
                    if Fly.SetSpeedSlider then
                        Fly.SetSpeedSlider(newSpeed)
                    end
                end
            end
        end
        local flyBegan = UserInputService.InputBegan:Connect(onFlyInputBegan)
        table.insert(Fly.Conns, flyBegan)

        local function onFlyInputEnded(input, gameProc)
            if input.UserInputType == Enum.UserInputType.Keyboard then
                local key = input.KeyCode
                if key == Enum.KeyCode.W then moveState.forward = 0
                elseif key == Enum.KeyCode.S then moveState.backward = 0
                elseif key == Enum.KeyCode.A then moveState.left = 0
                elseif key == Enum.KeyCode.D then moveState.right = 0
                end
            end
        end
        local flyEnded = UserInputService.InputEnded:Connect(onFlyInputEnded)
        table.insert(Fly.Conns, flyEnded)

    else
        Fly.IsFlying = false
        Workspace.Gravity = Fly.OriginalGravity
        humanoid.PlatformStand = false
        stopFlyAnimation()
        if hrp:FindFirstChild("FlyGyro") then hrp.FlyGyro:Destroy() end
        if hrp:FindFirstChild("FlyVelocity") then hrp.FlyVelocity:Destroy() end
        for _, conn in ipairs(Fly.Conns) do
            if conn.Connected then conn:Disconnect() end
        end
        Fly.Conns = {}
        moveState = {forward = 0, backward = 0, left = 0, right = 0}
        isBoosting = false
        Fly.CurrentCF = nil
    end
end

