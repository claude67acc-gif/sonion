-- Function to create a ghost copy of the player's character
local function createGhostCharacter()
    if not character then return end
    character.Archivable = true
    
    local success, cloned = pcall(function()
        return character:Clone()
    end)
    
    if success and cloned then
        ghostCharacter = cloned
        ghostCharacter.Name = "GhostESP"
        
        -- Clean up scripts, sounds, and constraints so they don't run
        for _, obj in pairs(ghostCharacter:GetDescendants()) do
            if obj:IsA("LuaSourceContainer") or obj:IsA("Sound") or obj:IsA("Constraint") then
                obj:Destroy()
            elseif obj:IsA("BasePart") then
                obj.CanCollide = false
                obj.Anchored = true
                obj.Transparency = 0.4
                obj.CastShadow = false
                obj.Material = Enum.Material.ForceField -- Animated hologram texture
            end
        end
        
        -- Clean up humanoid settings
        local hum = ghostCharacter:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
            pcall(function() hum.Animator:Destroy() end)
        end
        
        -- Add selection highlight for high-quality ESP look through walls
        local highlight = Instance.new("Highlight")
        highlight.Adornee = ghostCharacter
        highlight.FillColor = Color3.fromRGB(0, 0, 0) -- Black fill
        highlight.FillTransparency = 0.5
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255) -- White border
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Parent = ghostCharacter
        
        ghostCharacter.Parent = game.Workspace
    end
end

-- Function to update the destination ghost ESP above ground
local function updateMarker()
    if humanoidRootPart and humanoidRootPart.Parent and humanoidRootPart.Position.Y < 0 then
        if not ghostCharacter then
            createGhostCharacter()
        end
        
        if ghostCharacter then
            -- Match the player's horizontal position (locked to surface Y) and orientation
            local rotationOnly = humanoidRootPart.CFrame - humanoidRootPart.Position
            local targetCFrame = CFrame.new(humanoidRootPart.Position.X, lastGroundY, humanoidRootPart.Position.Z) * rotationOnly
            ghostCharacter:PivotTo(targetCFrame)
        end
    else
        destroyGhost()
    end
end

