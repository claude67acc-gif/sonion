local lagThreadActive = true

-- Standard Anchor Jitter Core Loop
task.spawn(function()
    while lagThreadActive do
        task.wait(FeatureStates.WaitTime)
        if FeatureStates.FakeLagActive and not FeatureStates.NetworkIssueActive then
            local char = lp.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp and not hrp.Anchored then
                hrp.Anchored = true
                task.wait(FeatureStates.DelayTime)
                if hrp and hrp.Parent then
                    hrp.Anchored = false
                end
            end
        end
    end
end)

-- High-Latency Rubberband (Walk & Snap Back) Thread Engine
task.spawn(function()
    while lagThreadActive do
        task.wait(0.05)
        if FeatureStates.FakeLagActive and FeatureStates.NetworkIssueActive then
            local char = lp.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                -- Store anchor point before network drop simulation simulation begins
                local lockCFrame = hrp.CFrame
                
                -- Allow player to walk away locally during the stall window
                task.wait(FeatureStates.DelayTime)
                
                -- Forcefully teleport back to correct server desync position
                if FeatureStates.FakeLagActive and FeatureStates.NetworkIssueActive and hrp and hrp.Parent then
                    hrp.CFrame = lockCFrame
                end
            end
        end
    end
end)

