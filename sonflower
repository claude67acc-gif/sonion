                            WaterColor        = TerrainObj.WaterColor,
                            WaterReflectance  = TerrainObj.WaterReflectance,
                            WaterTransparency = TerrainObj.WaterTransparency,
                            WaterWaveSize     = TerrainObj.WaterWaveSize,
                            WaterWaveSpeed    = TerrainObj.WaterWaveSpeed,
                        }
                    end
        
                    print(string.format("[Snapshot] Ready. Saved %d part properties, lighting, and all post-processing effects. Safe to run shaders.", colorCount))
        
            end
        -- ==========================================
        -- CUSTOM THEME: AESTHETIC
        -- ==========================================
        
        local function applyAesthetic(part)
            if part:IsA("BasePart") or part:IsA("Terrain") then
                if isCharacterPart(part) then return end
                if part.Name == "ZenTile" then return end
        
