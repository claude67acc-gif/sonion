                                gui.Enabled = true
                            end
                        end
                    end
                end
            end
        end
    end

    GuiService.MenuOpened:Connect(function()
        setHubGuiVisibility(false)
    end)

    GuiService.MenuClosed:Connect(function()
        setHubGuiVisibility(true)
    end)
end

