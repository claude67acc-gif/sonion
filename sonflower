        targetScale = 0.5
        targetX = -60
    end
    
    local minimizedPos = UDim2.new(targetScale, targetX, 0, -37)
    
    TweenService:Create(mainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 120, 0, 42),
        Position = minimizedPos
