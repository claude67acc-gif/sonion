---- Autocomplete Suggestions logic
local availableCommands = {}
for cmdName, _ in pairs(EmbeddedScripts) do
    table.insert(availableCommands, cmdName)
end
table.sort(availableCommands)

local selectedSuggestionIndex = 0
local suggestionButtons = {}

local function highlightSuggestion(btn)
    createTween(btn, TweenInfo.new(0.15), {
        BackgroundTransparency = 0,
        BackgroundColor3 = Color3.fromRGB(30, 30, 30), -- Highlight matching Theme.Input
        TextColor3 = Color3.fromRGB(255, 255, 255) -- White matching Theme.Text
    })
end

local function unhighlightSuggestion(btn)
    createTween(btn, TweenInfo.new(0.15), {
        BackgroundTransparency = 1,
        TextColor3 = Color3.fromRGB(160, 160, 160) -- Muted matching Theme.TextMuted
    })
end

local function scrollToSuggestion(index)
    if not SuggestionsFrame or not SuggestionsFrame.Visible then return end
    local buttonHeight = 32
    local totalHeight = SuggestionsFrame.CanvasSize.Y.Offset
    local frameHeight = SuggestionsFrame.Size.Y.Offset
    if totalHeight <= frameHeight then return end
    
    local targetY = (index - 3) * buttonHeight
    targetY = math.clamp(targetY, 0, totalHeight - frameHeight)
    SuggestionsFrame.CanvasPosition = Vector2.new(0, targetY)
end

local function updateSuggestions()
    local query = string.lower(SearchBox.Text)
    
    -- Clear old suggestions
    for _, child in pairs(SuggestionsFrame:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    table.clear(suggestionButtons)
    selectedSuggestionIndex = 0
    
    if query == "" then
        SuggestionsFrame.Visible = false
        return
    end
    
    local matches = {}
    for _, cmd in ipairs(availableCommands) do
        if string.find(cmd, query) then
            table.insert(matches, cmd)
        end
    end
    
    if #matches == 0 then
        SuggestionsFrame.Visible = false
        return
    end
    
    for i, cmd in ipairs(matches) do
        local btn = Instance.new("TextButton")
        btn.Name = cmd
        btn.Size = UDim2.new(1, 0, 0, 30)
        btn.BackgroundTransparency = 1
        btn.BorderSizePixel = 0
        btn.Font = Enum.Font.GothamMedium
        btn.Text = "  " .. cmd
        btn.TextColor3 = Color3.fromRGB(160, 160, 160) -- Muted text matching Theme.TextMuted
        btn.TextSize = 13
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.AutoButtonColor = false
        btn.ZIndex = 16
        btn.Parent = SuggestionsFrame
        
        table.insert(suggestionButtons, btn)
        
        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 6)
        btnCorner.Parent = btn
        
        btn.MouseEnter:Connect(function()
            selectedSuggestionIndex = i
            highlightSuggestion(btn)
            for j, otherBtn in ipairs(suggestionButtons) do
                if j ~= i then
                    unhighlightSuggestion(otherBtn)
                end
            end
        end)
        
        btn.MouseLeave:Connect(function()
            unhighlightSuggestion(btn)
        end)
        
        btn.MouseButton1Click:Connect(function()
            SearchBox.Text = cmd
            SuggestionsFrame.Visible = false
            runCommand(cmd)
        end)
    end
    
    local shownCount = math.min(6, #matches)
    SuggestionsFrame.Size = UDim2.new(0, CommandBarFrame.Size.X.Offset, 0, (shownCount * 32) + 12)
    SuggestionsFrame.CanvasSize = UDim2.new(0, 0, 0, (#matches * 32) + 12)
    SuggestionsFrame.Visible = true
end

SearchBox:GetPropertyChangedSignal("Text"):Connect(updateSuggestions)

-- Keybind hide/show and suggestions keyboard navigation listener
UserInputService.InputBegan:Connect(function(input, processed)
    -- Handle suggestions navigation when SearchBox has focus and dropdown is visible
    if UserInputService:GetFocusedTextBox() == SearchBox and SuggestionsFrame.Visible then
        if input.KeyCode == Enum.KeyCode.Down then
            if #suggestionButtons > 0 then
                if selectedSuggestionIndex > 0 and suggestionButtons[selectedSuggestionIndex] then
                    unhighlightSuggestion(suggestionButtons[selectedSuggestionIndex])
                end
                selectedSuggestionIndex = selectedSuggestionIndex + 1
                if selectedSuggestionIndex > #suggestionButtons then
                    selectedSuggestionIndex = 1
                end
                local currentBtn = suggestionButtons[selectedSuggestionIndex]
                if currentBtn then
                    highlightSuggestion(currentBtn)
                    scrollToSuggestion(selectedSuggestionIndex)
                end
            end
            return
        elseif input.KeyCode == Enum.KeyCode.Up then
            if #suggestionButtons > 0 then
                if selectedSuggestionIndex > 0 and suggestionButtons[selectedSuggestionIndex] then
                    unhighlightSuggestion(suggestionButtons[selectedSuggestionIndex])
                end
                selectedSuggestionIndex = selectedSuggestionIndex - 1
                if selectedSuggestionIndex < 1 then
                    selectedSuggestionIndex = #suggestionButtons
                end
                local currentBtn = suggestionButtons[selectedSuggestionIndex]
                if currentBtn then
                    highlightSuggestion(currentBtn)
                    scrollToSuggestion(selectedSuggestionIndex)
                end
            end
            return
        end
    end

    -- Toggle search bar focus with F7
    if input.KeyCode == Enum.KeyCode.F7 then
        local searchBoxFocused = (UserInputService:GetFocusedTextBox() == SearchBox)
        if searchBoxFocused then
            SearchBox:ReleaseFocus()
            SuggestionsFrame.Visible = false
        else
            if not PillActive then
                toggleCommandBar()
            end
            task.defer(function()
                SearchBox:CaptureFocus()
            end)
        end
        return
    end

    -- Other menu toggles when not typing
    local isTyping = UserInputService:GetFocusedTextBox() ~= nil
    if not isTyping then
        if input.KeyCode == GUI_KEYBIND then
            toggleGUI()
        elseif input.KeyCode == Enum.KeyCode.K then
            toggleCommandBar()
        end
    end
end)

