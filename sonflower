-- Facebang Logic
local active = false
local facebangAnim = Instance.new("Animation")
facebangAnim.AnimationId = "rbxassetid://96094625577723"
local animTrack = nil

local attachConnection = nil
local noclipConnection = nil
local targetPlayer = nil

local sethidden = sethiddenproperty or set_hidden_property or set_hidden_prop

local function getNearestPlayer()
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    local target = nil
    local minDist = math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
            if dist < minDist then
                minDist = dist
                target = p
            end
        end
    end
    return target
end

local function startFacebang()
    active = true
    statusText.Text = "ACTIVE"
    statusText.TextColor3 = Theme.Text
    statusIndicator.BackgroundColor3 = Theme.Text
    statusDot.BackgroundColor3 = Theme.Text

    local char = lp.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")

    if hum then
        local animator = hum:FindFirstChildOfClass("Animator") or Instance.new("Animator", hum)
        for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
            track:Stop()
        end
        
        -- Disable default Animate script
        local animate = char:FindFirstChild("Animate")
        if animate then
            animate.Disabled = true
        end
        
        local anim = Instance.new("Animation")
        anim.AnimationId = "rbxassetid://96094625577723"
        
        pcall(function()
            animTrack = animator:LoadAnimation(anim)
            animTrack.Looped = true
            animTrack:Play()
        end)
    end

    targetPlayer = getNearestPlayer()

    -- Attaching to nearest player front/face level using AttachHub style task.spawn loop
    if targetPlayer and hrp then
        task.spawn(function()
            while active and targetPlayer do
                local myChar = lp.Character
                local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
                local tChar = targetPlayer.Character
                local tHrp = tChar and tChar:FindFirstChild("HumanoidRootPart")
                local tPart = tChar and (tChar:FindFirstChild("Head") or tHrp)
                
                if myHrp and tHrp and tPart then
                    pcall(function()
                        sethiddenproperty(myHrp, "PhysicsRepRootPart", tHrp)
                    end)
                    local offset = (tPart.Name == "Head") and CFrame.new(0, 1.1, -1.1) or CFrame.new(0, 1.5, -1.1)
                    myHrp.CFrame = tPart.CFrame * offset * CFrame.Angles(0, math.rad(180), 0)
                    myHrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    myHrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                end
                task.wait()
            end
        end)

        noclipConnection = RunService.Stepped:Connect(function()
            local myChar = lp.Character
            if myChar then
                for _, part in ipairs(myChar:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end
        end)
    end
end

local function stopFacebang()
    active = false
    statusText.Text = "IDLE"
    statusText.TextColor3 = Theme.TextMuted
    statusIndicator.BackgroundColor3 = Theme.TextMuted
    statusDot.BackgroundColor3 = Theme.TextMuted

    if animTrack then
        pcall(function() animTrack:Stop() end)
        animTrack = nil
    end
    
    -- Re-enable default Animate script
    local char = lp.Character
    local animate = char and char:FindFirstChild("Animate")
    if animate then
        animate.Disabled = false
    end

    if attachConnection then
        attachConnection:Disconnect()
        attachConnection = nil
    end

    if noclipConnection then
        noclipConnection:Disconnect()
        noclipConnection = nil
    end
    targetPlayer = nil
end

local function toggleFacebang()
    if active then
        stopFacebang()
    else
        startFacebang()
    end
end

