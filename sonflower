    createCorner(bindBtn, 6); local stroke = createStroke(bindBtn, Theme.Border, 1)

    bindBtn.MouseButton1Click:Connect(function()
        if listeningForKey then return end
        listeningForKey = isForward and "forward" or "reverse"
        bindBtn.Text = "..."; stroke.Color = Theme.Text
    end)

    return bindBtn, stroke
end

