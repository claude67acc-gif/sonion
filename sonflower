-- Unified Key Handler Framework Hook
UserInputService.InputBegan:Connect(function(input, processed)
    if listeningForKey then
        if input.UserInputType == Enum.UserInputType.Keyboard then
            local key = input.KeyCode
            if key == Enum.KeyCode.Escape or key == Enum.KeyCode.Backspace then
                key = Enum.KeyCode.Unknown
            end
            if listeningForKey == "forward" then
                forwardKey = key; fwdBindBtn.Text = key == Enum.KeyCode.Unknown and "NONE" or key.Name
                fwdStroke.Color = Theme.Border
            else
                reverseKey = key; revBindBtn.Text = key == Enum.KeyCode.Unknown and "NONE" or key.Name
                revStroke.Color = Theme.Border
            end
            listeningForKey = nil
        end
        return
    end

    if processed or UserInputService:GetFocusedTextBox() then return end
    if input.UserInputType == Enum.UserInputType.Keyboard then
        if input.KeyCode == forwardKey and forwardKey ~= Enum.KeyCode.Unknown then
            if spinActive and spinDirection == 1 then stopSpin() else startSpin(1) end
        elseif input.KeyCode == reverseKey and reverseKey ~= Enum.KeyCode.Unknown then
            if spinActive and spinDirection == -1 then stopSpin() else startSpin(-1) end
        end
    end
end)

