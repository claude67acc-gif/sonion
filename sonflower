local function createInstance(className, properties)
    local obj = Instance.new(className)
    for k, v in pairs(properties) do
        if k ~= "Parent" then
            obj[k] = v
        end
    end
    if properties.Parent then
        obj.Parent = properties.Parent
    end
    return obj
end

