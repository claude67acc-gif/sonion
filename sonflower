    local UserInputService = game:GetService("UserInputService")
    local RunService = game:GetService("RunService")
    
    local lp = Players.LocalPlayer
    local pgui = lp:WaitForChild("PlayerGui")
    
    -- Clear snapshots if server/job has changed
    if getgenv().LAST_JOB_ID ~= game.JobId then
        getgenv().ORIGINAL_COLORS = nil
        getgenv().ORIGINAL_MATERIALS = nil
        getgenv().ORIGINAL_REFLECTANCES = nil
        getgenv().ORIGINAL_LIGHTING = nil
        getgenv().ORIGINAL_LIGHTING_CHILDREN = nil
        getgenv().ORIGINAL_TERRAIN_CHILDREN = nil
        getgenv().ORIGINAL_WATER = nil
        getgenv().LAST_JOB_ID = game.JobId
    end
    
    -- Destroy existing UI if present
    local existing = pgui:FindFirstChild("ShadersGui")
    if existing then
        existing:Destroy()
    end
    
    -- Embedded Shaders Code
    local EmbeddedShaders = {
        aesthetic = function()
            local Players = game:GetService("Players")
            local Lighting = game:GetService("Lighting")
            local Workspace = game:GetService("Workspace")
            local CollectionService = game:GetService("CollectionService")
            local LocalPlayer = Players.LocalPlayer
            local Terrain = Workspace:FindFirstChildOfClass("Terrain")
        
            -- Ensure connection tracker exists
            getgenv().SHADER_CONNECTIONS = getgenv().SHADER_CONNECTIONS or {}
        
            -- Helper to create tagged objects that are excluded from snapshots
            local function local_create_tagged(className, parent)
                local inst = Instance.new(className)
                CollectionService:AddTag(inst, "XnoctisShaderObject")
                if parent then
                    inst.Parent = parent
                end
                return inst
            end
        
            local function isCharacterPart(part)
            for _, plr in ipairs(Players:GetPlayers()) do
                local char = plr.Character
                if char and part:IsDescendantOf(char) then return true end
            end
            return false
        end
            -- Only take snapshot if not already snapshotted
            if not getgenv().ORIGINAL_LIGHTING or not next(getgenv().ORIGINAL_LIGHTING) then
        getgenv().ORIGINAL_COLORS      = {}
                    getgenv().ORIGINAL_MATERIALS   = {}
                    getgenv().ORIGINAL_REFLECTANCES = {}
                    getgenv().ORIGINAL_LIGHTING    = {}
                    getgenv().ORIGINAL_WATER       = nil
                    getgenv().ORIGINAL_SKY         = nil
                    getgenv().ORIGINAL_ATMO        = nil
        
                    -- Snapshot every BasePart color, material, and reflectance in the workspace
                    local colorCount = 0
                    for _, obj in ipairs(Workspace:GetDescendants()) do
                        if obj:IsA("BasePart") and not isCharacterPart(obj) then
                            pcall(function()
                                getgenv().ORIGINAL_COLORS[obj] = obj.Color
                                getgenv().ORIGINAL_MATERIALS[obj] = obj.Material
                                getgenv().ORIGINAL_REFLECTANCES[obj] = obj.Reflectance
                                colorCount = colorCount + 1
                            end)
                        end
                    end
        
                    table.insert(getgenv().SHADER_CONNECTIONS, Workspace.DescendantAdded:Connect(function(obj)
                        task.defer(function()
                            if obj:IsA("BasePart") and not isCharacterPart(obj) then
                                pcall(function()
                                    if not getgenv().ORIGINAL_COLORS[obj] then
                                        getgenv().ORIGINAL_COLORS[obj] = obj.Color
                                    end
                                    if not getgenv().ORIGINAL_MATERIALS[obj] then
                                        getgenv().ORIGINAL_MATERIALS[obj] = obj.Material
                                    end
                                    if not getgenv().ORIGINAL_REFLECTANCES[obj] then
                                        getgenv().ORIGINAL_REFLECTANCES[obj] = obj.Reflectance
                                    end
                                end)
                            end
                        end)
                    end))
        
                    local L = getgenv().ORIGINAL_LIGHTING
                    L.Technology               = Lighting.Technology
                    L.Ambient                  = Lighting.Ambient
                    L.OutdoorAmbient           = Lighting.OutdoorAmbient
                    L.Brightness               = Lighting.Brightness
                    L.ColorShift_Bottom        = Lighting.ColorShift_Bottom
                    L.ColorShift_Top           = Lighting.ColorShift_Top
                    L.FogColor                 = Lighting.FogColor
                    L.FogEnd                   = Lighting.FogEnd
                    L.FogStart                 = Lighting.FogStart
                    L.GlobalShadows            = Lighting.GlobalShadows
                    L.ShadowSoftness           = Lighting.ShadowSoftness
                    L.EnvironmentDiffuseScale  = Lighting.EnvironmentDiffuseScale
                    L.EnvironmentSpecularScale = Lighting.EnvironmentSpecularScale
                    L.ExposureCompensation     = Lighting.ExposureCompensation
                    L.ClockTime                = Lighting.ClockTime
                    L.GeographicLatitude       = Lighting.GeographicLatitude
        
                    getgenv().ORIGINAL_LIGHTING_CHILDREN = {}
                    for _, child in ipairs(Lighting:GetChildren()) do
                        if not CollectionService:HasTag(child, "XnoctisShaderObject") then
                            pcall(function()
                                child.Archivable = true
                                table.insert(getgenv().ORIGINAL_LIGHTING_CHILDREN, child:Clone())
                            end)
                        end
                    end
        
                    getgenv().ORIGINAL_TERRAIN_CHILDREN = {}
                    local Terrain = Workspace:FindFirstChildOfClass("Terrain")
                    if Terrain then
                        for _, child in ipairs(Terrain:GetChildren()) do
                            if not CollectionService:HasTag(child, "XnoctisShaderObject") then
                                pcall(function()
                                    child.Archivable = true
                                    table.insert(getgenv().ORIGINAL_TERRAIN_CHILDREN, child:Clone())
                                end)
                            end
                        end
                    end
        
                    local TerrainObj = Workspace:FindFirstChildOfClass("Terrain")
