local function refreshButtonAppearance(btn)
    if not btn then return end
    local isMute = (btn == MuteBtn)
    local isHide = (btn == HideBtn)
    local active = false
    if attachTarget then
        if isMute and _G.MutedPlayers[attachTarget] then active = true end
        if isHide and _G.HiddenPlayers[attachTarget] then active = true end
    end
    
    local hovered = buttonHovered[btn]
    
    if active then
        local targetBg = Color3.fromRGB(255, 255, 255)
        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = targetBg,
            TextColor3 = Color3.fromRGB(0, 0, 0)
        }):Play()
    else
        local targetBg = hovered and Color3.fromRGB(50, 50, 60) or Color3.fromRGB(35, 35, 40)
        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = targetBg,
            TextColor3 = Color3.fromRGB(255, 255, 255)
        }):Play()
    end
end

