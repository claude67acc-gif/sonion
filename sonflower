local function filterString(text)
    text = string.gsub(text, "[%p]+", "")
    local function filterWord(word)
        local iterationCount = 0
        for i = 1, #word do
            if (i % 2 == 0) then
                i = i + iterationCount
                local a = string.sub(word, 0, i)
                local b = string.sub(word, i + 1, -1)
                word = a .. bypassSeperater .. b
                iterationCount = iterationCount + #bypassSeperater
            end
        end
        return word
    end
    local words = string.split(text, " ")
    for i = 1, #words do
        words[i] = filterWord(words[i])
    end
    return table.concat(words, " ")
end

local function randomCapitalize(text)
    local result = ""
    for char in text:gmatch(".") do
        if math.random(1, 2) == 1 then
            result = result .. char:upper()
        else
            result = result .. char:lower()
        end
    end
    return result
end

local enderChars = { "\226\128\139", "\226\128\140", "\226\128\141", "\226\128\142", "\226\128\143" }
local function addRandomEnder(text)
    local ender = ""
    local length = math.random(1, 4)
    for i = 1, length do
        ender = ender .. enderChars[math.random(1, #enderChars)]
    end
    return text .. ender
end

local function sendChat(msg)
    task.spawn(function()
        pcall(function()
            if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
                local textChannels = TextChatService:FindFirstChild("TextChannels")
                if textChannels then
                    local channel = textChannels:FindFirstChild("RBXGeneral")
                    if channel then
                        channel:SendAsync(msg)
                    end
                end
            else
                local chatEvents = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
                if chatEvents then
                    local sayMsg = chatEvents:FindFirstChild("SayMessageRequest")
                    if sayMsg then
                        sayMsg:FireServer(msg, "All")
                    end
                end
            end
        end)
    end)
end

