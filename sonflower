-- Mobile Switch System Toggle Element Row Helper (Chat Spammer Style)
local function createToggle(parent, labelText, defaultValue, layoutOrder, callback)
    local toggleFrame = createInstance("Frame", {
        Size = UDim2.new(1, 0, 0, 24), 
        BackgroundTransparency = 1,
        LayoutOrder = layoutOrder,
        Parent = parent
    })

    createInstance("TextLabel", {
        Size = UDim2.new(1, -50, 1, 0), 
        BackgroundTransparency = 1,
        Text = labelText,
        Font = Enum.Font.GothamBold,
        TextSize = 10,
        TextColor3 = Theme.TextMuted,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center, 
        Parent = toggleFrame
    })

    local switchTrack = createInstance("Frame", {
        Size = UDim2.new(0, 36, 0, 18), 
        Position = UDim2.new(1, -36, 0.5, -9),
        BackgroundColor3 = defaultValue and Theme.Accent1 or Theme.InactiveToggle,
        BorderSizePixel = 0,
        Parent = toggleFrame
    })
    createCorner(switchTrack, 9)
    createStroke(switchTrack, Theme.Border, 1)

    local switchKnob = createInstance("Frame", {
        Size = UDim2.new(0, 12, 0, 12),
        Position = defaultValue and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6),
        BackgroundColor3 = defaultValue and Theme.Header or Theme.TextMuted,
        BorderSizePixel = 0,
        Parent = switchTrack
    })
    createCorner(switchKnob, 6)

    local state = defaultValue

    local function setToggle(newState)
        state = newState
        local targetPos = state and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6)
        local targetColor = state and Theme.Text or Theme.InactiveToggle
        local knobColor = state and Theme.Header or Theme.TextMuted

        TweenService:Create(switchKnob, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = targetPos,
            BackgroundColor3 = knobColor
        }):Play()
        TweenService:Create(switchTrack, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            BackgroundColor3 = targetColor
        }):Play()

        callback(state)
    end

    local clickBtn = createInstance("TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        Parent = toggleFrame
    })

    clickBtn.MouseButton1Click:Connect(function()
        setToggle(not state)
    end)

    return {
        Set = setToggle,
        Get = function() return state end
    }
end

