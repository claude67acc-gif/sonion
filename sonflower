-- Helper to create a slider row inside scrolling panel (matches InvincFly Style: no knob, custom strokes)
local function createSliderRow(parent, labelText, minValue, maxValue, defaultValue, callback)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, 0, 0, 50)
    row.BackgroundColor3 = Color3.fromRGB(15, 15, 18) -- Sleek solid flat card
    row.BackgroundTransparency = 0
    row.BorderSizePixel = 0
    row.Parent = parent
    createCorner(row, 8)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.4, 0, 1, 0)
    label.Position = UDim2.new(0, 15, 0, 0)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.GothamMedium
    label.Text = string.upper(labelText)
    label.TextSize = 10
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextTransparency = 0.25
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = row

    -- Background Bar
    local sliderBg = Instance.new("Frame")
    sliderBg.Size = UDim2.new(0, 120, 0, 6)
    sliderBg.Position = UDim2.new(1, -165, 0.5, -3)
    sliderBg.BackgroundColor3 = Color3.fromRGB(48, 48, 56)
    sliderBg.BorderSizePixel = 0
    sliderBg.Parent = row
    createCorner(sliderBg, 3)
    createStroke(sliderBg, Color3.fromRGB(60, 60, 60), 1, 0)

    -- Fill Bar
    local sliderFill = Instance.new("Frame")
    sliderFill.Size = UDim2.new((defaultValue - minValue) / (maxValue - minValue), 0, 1, 0)
    sliderFill.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sliderFill.BorderSizePixel = 0
    sliderFill.Parent = sliderBg
    createCorner(sliderFill, 3)

    -- Value TextBox
    local sliderValLabel = Instance.new("TextBox")
    sliderValLabel.Size = UDim2.new(0, 35, 0, 20)
    sliderValLabel.Position = UDim2.new(1, -35, 0.5, -10)
    sliderValLabel.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    sliderValLabel.BorderSizePixel = 0
    sliderValLabel.Font = Enum.Font.GothamBold
    sliderValLabel.Text = tostring(math.floor(defaultValue))
    sliderValLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    sliderValLabel.TextSize = 10
    sliderValLabel.ClearTextOnFocus = false
    sliderValLabel.Parent = row
    createCorner(sliderValLabel, 4)
    createStroke(sliderValLabel, Color3.fromRGB(60, 60, 60), 1, 0)

    local currentValue = defaultValue
    local sliderActive = false

    local function updateSlider(input)
        local posX = input.Position.X - sliderBg.AbsolutePosition.X
        local percentage = math.clamp(posX / sliderBg.AbsoluteSize.X, 0, 1)
        currentValue = math.round(minValue + (maxValue - minValue) * percentage)
        
        sliderFill.Size = UDim2.new(percentage, 0, 1, 0)
        sliderValLabel.Text = tostring(currentValue)
        callback(currentValue)
    end

    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            sliderActive = true
            updateSlider(input)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if sliderActive and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(input)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            sliderActive = false
        end
    end)

    local function setVal(val)
        currentValue = math.clamp(val, minValue, maxValue)
        local percentage = (currentValue - minValue) / (maxValue - minValue)
        sliderFill.Size = UDim2.new(percentage, 0, 1, 0)
        sliderValLabel.Text = tostring(currentValue)
        callback(currentValue)
    end

    sliderValLabel.FocusLost:Connect(function(enterPressed)
        local val = tonumber(sliderValLabel.Text)
        if val then
            setVal(val)
        else
            sliderValLabel.Text = tostring(currentValue)
        end
    end)

    return row, setVal
end

