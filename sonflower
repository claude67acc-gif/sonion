-- Function to get the dynamic height offset (from HumanoidRootPart center to feet bottom)
local function getCharacterHeightOffset()
    if not character or not humanoidRootPart then
        return 3.0
    end
    
    local hrpY = humanoidRootPart.Position.Y
    local lowestY = hrpY
    
    -- Look for foot/leg parts to find the lowest point
    for _, part in ipairs(character:GetChildren()) do
        if part:IsA("BasePart") then
            local name = part.Name:lower()
            if name:find("foot") or name:find("leg") or name:find("sole") then
                local bottomY = part.Position.Y - (part.Size.Y / 2)
                if bottomY < lowestY then
                    lowestY = bottomY
                end
            end
        end
    end
    
    local offset = hrpY - lowestY
    if offset > 0.5 and offset < 6 then
        return offset
    end
    
    if humanoid then
        if humanoid.RigType == Enum.HumanoidRigType.R15 then
            return humanoid.HipHeight + (humanoidRootPart.Size.Y / 2)
        else
            return 3.0
        end
    end
    
    return 3.0
end

-- Function to find top ground level dynamically
local function findInitialGroundLevel()
    local baseplateSurfaceY = secondBaseplate.Position.Y + (secondBaseplate.Size.Y / 2)
    if humanoidRootPart.Position.Y > baseplateSurfaceY + 5 then
        return humanoidRootPart.Position.Y
    else
        local raycastParams = RaycastParams.new()
        raycastParams.FilterType = Enum.RaycastFilterType.Exclude
        local filterList = {character, secondBaseplate}
        if ghostCharacter then table.insert(filterList, ghostCharacter) end
        raycastParams.FilterDescendantsInstances = filterList
        
        local origin = Vector3.new(humanoidRootPart.Position.X, 500, humanoidRootPart.Position.Z)
        local direction = Vector3.new(0, -1000, 0)
        local raycastResult = workspace:Raycast(origin, direction, raycastParams)
        if raycastResult then
            return raycastResult.Position.Y + getCharacterHeightOffset()
        end
    end
    return 3.0
end

lastGroundY = findInitialGroundLevel()

-- Function to calculate the height needed to reach the baseplate
local function getHeightToBaseplate()
    local baseplateSurfaceY = secondBaseplate.Position.Y + (secondBaseplate.Size.Y / 2)
    local feetOffset = getCharacterHeightOffset()
    return baseplateSurfaceY + feetOffset
end

-- Function to set up the height lock
local function setupHeightLock()
    if heightLock then
        pcall(function() heightLock:Destroy() end)
    end
    heightLock = Instance.new("BodyPosition")
    heightLock.Name = "HeightLock"
    heightLock.MaxForce = Vector3.new(0, 100000, 0) -- Only lock Y axis
    
    local targetY = humanoidRootPart.Position.Y
    local baseplateSurfaceY = secondBaseplate.Position.Y + (secondBaseplate.Size.Y / 2)
    if humanoidRootPart.Position.Y < baseplateSurfaceY + 10 then
        targetY = getHeightToBaseplate()
    end
    
    heightLock.Position = Vector3.new(0, targetY, 0)
    heightLock.P = 10000
    heightLock.D = 1000
    heightLock.Parent = humanoidRootPart
end

-- Function to set noclip state
local function setNoclip(state)
    noclipEnabled = state
    
    if noclipEnabled then
        statusText.Text = "ACTIVE"
        statusText.TextColor3 = Theme.Text
        statusIndicator.BackgroundColor3 = Theme.Text
        statusDot.BackgroundColor3 = Theme.Text
        
        -- Enable collision disabling
        if not noclipConnection then
            originalCollisions = {}
            if character then
                for _, part in pairs(character:GetDescendants()) do
                    if part:IsA("BasePart") then
                        originalCollisions[part] = part.CanCollide
                        part.CanCollide = false
                    end
                end
            end
            
            noclipConnection = RunService.Stepped:Connect(function()
                if character then
                    for _, part in pairs(character:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = false
                        end
                    end
                end
            end)
        end
        
        -- Enable height lock at current height
        if not isTweening then
            setupHeightLock()
        end
    else
        statusText.Text = "IDLE"
        statusText.TextColor3 = Theme.TextMuted
        statusIndicator.BackgroundColor3 = Theme.TextMuted
        statusDot.BackgroundColor3 = Theme.TextMuted
        
        -- Disable collision disabling
        if noclipConnection then
            noclipConnection:Disconnect()
            noclipConnection = nil
        end
        
        -- Restore original character collisions
        if character then
            for part, wasCollidable in pairs(originalCollisions) do
                if part and part.Parent then
                    part.CanCollide = wasCollidable
                end
            end
        end
        originalCollisions = {}
        
        -- Remove height lock so player can jump and fall
        if heightLock then
            pcall(function() heightLock:Destroy() end)
            heightLock = nil
        end
    end
end

-- Function to tween the player to a target position
local function tweenPlayerTo(targetPosition, targetNoclipState)
    if isTweening then return end
    
    isTweening = true
    
    -- Force noclip ON temporarily for the tween so player doesn't get stuck in floor/walls
    if not noclipConnection then
        noclipConnection = RunService.Stepped:Connect(function()
            if character then
                for _, part in pairs(character:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end
        end)
    end
    
    -- Set up height lock for full movement
    if heightLock then
        pcall(function() heightLock:Destroy() end)
    end
    heightLock = Instance.new("BodyPosition")
    heightLock.Name = "HeightLock"
    heightLock.MaxForce = Vector3.new(100000, 100000, 100000)
    heightLock.Position = humanoidRootPart.Position
    heightLock.P = 10000
    heightLock.D = 1000
    heightLock.Parent = humanoidRootPart
    
    -- Save original orientation
    local originalCFrame = humanoidRootPart.CFrame
    local originalLookVector = originalCFrame.LookVector
    
    -- Set PlatformStand to true to prevent jumping during tween
    humanoid.PlatformStand = true
    
    -- Create a CFrame that preserves the original facing direction
    local targetCFrame = CFrame.new(targetPosition) * CFrame.lookAt(targetPosition, targetPosition + originalLookVector)
    
    -- Create a BodyGyro to maintain orientation
    local bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(100000, 100000, 100000)
    bodyGyro.CFrame = targetCFrame
    bodyGyro.P = 10000
    bodyGyro.D = 1000
    bodyGyro.Parent = humanoidRootPart
    
    -- Fallback cleanup using Debris
    game:GetService("Debris"):AddItem(bodyGyro, FeatureStates.TweenDuration + 0.1)
    
    -- Use TweenService to animate the body position target smoothly over time
    local tweenInfo = TweenInfo.new(FeatureStates.TweenDuration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local tween = TweenService:Create(heightLock, tweenInfo, {Position = targetPosition})
    tween:Play()
    
    tween.Completed:Connect(function()
        -- Reset states
        isTweening = false
        humanoid.PlatformStand = false
        
        -- Clean up gyro
        if bodyGyro and bodyGyro.Parent then
            bodyGyro:Destroy()
        end
        
        -- Set the target noclip state
        setNoclip(targetNoclipState)
        
        -- If noclip was target-enabled, lock the Y position at the new target height
        if targetNoclipState then
            if heightLock and heightLock.Parent then
                heightLock.MaxForce = Vector3.new(0, 100000, 0)
                heightLock.Position = Vector3.new(0, targetPosition.Y, 0)
            end
        end
    end)
end

