-- Network Simulation/Tracking Thread Frameworks
local function StartTrackingAnimations(player)
    if not player or not player.Character then return end
    local animator = player.Character:WaitForChild("Humanoid"):WaitForChild("Animator")

    TrackingAnimations = true
    AnimationTracks = {}
    CurrentClip = {
        Name = GenerateClipName(player.Name),
        PlayerName = player.Name,
        Events = {},
        StartTime = tick(),
    }

    task.spawn(function()
        while TrackingAnimations do
            if not animator or not animator.Parent then break end
            local tracks = animator:GetPlayingAnimationTracks()
            local elapsed = tick() - CurrentClip.StartTime
            
            for _, track in pairs(tracks) do
                local id = track.Animation.AnimationId
                if not AnimationTracks[id] or AnimationTracks[id].Stopped then
                    AnimationTracks[id] = {
                        Track = track, Stopped = false, LastTimePos = track.TimePosition, LastUpdate = elapsed, LastSpeed = track.Speed, IsFrozen = false
                    }
                    table.insert(CurrentClip.Events, {
                        Type = "Start", AnimationId = id, Time = elapsed, Speed = track.Speed, Weight = track.WeightCurrent, TimePosition = track.TimePosition
                    })
                else
                    local data = AnimationTracks[id]
                    local expected = data.LastTimePos + (elapsed - data.LastUpdate) * data.LastSpeed
                    local isFrozen = math.abs(track.TimePosition - data.LastTimePos) < 0.01 and track.Speed ~= 0
                    
                    if isFrozen ~= data.IsFrozen then
                        table.insert(CurrentClip.Events, {Type = "Freeze", AnimationId = id, Time = elapsed, IsFrozen = isFrozen})
                        data.IsFrozen = isFrozen
                    end
                    if math.abs(track.TimePosition - expected) > 0.1 then
                        table.insert(CurrentClip.Events, {Type = "TimeJump", AnimationId = id, Time = elapsed, NewPosition = track.TimePosition})
                    end
                    if math.abs(track.Speed - data.LastSpeed) > 0.01 then
                        table.insert(CurrentClip.Events, {Type = "Speed", AnimationId = id, Time = elapsed, Speed = track.Speed})
                        data.LastSpeed = track.Speed
                    end
                    
                    data.LastTimePos = track.TimePosition
                    data.LastUpdate = elapsed
                end
            end
            task.wait(0.03)
        end
    end)
end

